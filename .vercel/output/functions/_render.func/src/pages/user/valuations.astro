---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Icon from '../../components/Icon.astro';
---
<DashboardLayout title="My Valuations" subtitle="View all your submitted valuations" role="user" activePage="valuations">

  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <h1>My Valuations</h1>
      <p>All valuations submitted by you</p>
    </div>
    <a href="/user/add-valuation" class="btn btn-primary"><Icon name="plus" /> Add Valuation</a>
  </div>

  <div class="card">
    <!-- Card Header -->
    <div class="card-header">
      <div class="card-title">
        <div class="icon" style="background:var(--blue-100);color:var(--blue-700);"><Icon name="clipboard" size="14"/></div>
        Valuations List
        <span class="badge badge-blue" id="countBadge">Loading…</span>
      </div>
      <div style="display:flex;gap:8px;">
        <div class="search-bar">
          <span class="search-icon"><Icon name="search" size="14"/></span>
          <input type="text" class="form-control" placeholder="Search…" style="width:200px;" id="vsearch" />
        </div>
      </div>
    </div>

    <!-- Status Filter Tabs -->
    <div style="padding:10px 22px;border-bottom:1px solid var(--blue-50);display:flex;gap:7px;flex-wrap:wrap;">
      <button class="btn btn-sm btn-primary"   id="fs-all"      onclick="setStatusFilter('all')">All</button>
      <button class="btn btn-sm btn-secondary" id="fs-approved" onclick="setStatusFilter('approved')"><Icon name="check" size="14"/> Approved</button>
      <button class="btn btn-sm btn-secondary" id="fs-pending"  onclick="setStatusFilter('pending')"><Icon name="clock" size="14"/> Pending</button>
      <button class="btn btn-sm btn-secondary" id="fs-rejected" onclick="setStatusFilter('rejected')"><Icon name="x" size="14"/> Rejected</button>
    </div>

    <!-- Table -->
    <div class="table-wrapper" style="border:none;border-radius:0;">
      <table id="vtable">
        <thead>
          <tr>
            <th>ID</th>
            <th>Register No.</th>
            <th>Make</th>
            <th>Model</th>
            <th>YOM</th>
            <th>Market Value</th>
            <th>Date</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="vtbody">
          <tr><td colspan="9" style="text-align:center;padding:32px;color:var(--neutral-400);">Loading…</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Footer -->
    <div style="padding:12px 22px;border-top:1px solid var(--blue-50);font-size:.79rem;color:var(--neutral-500);">
      Showing <span id="showCount">0</span> valuation(s)
    </div>
  </div>
</DashboardLayout>

<script>
const API   = 'http://localhost:8080';
const token = localStorage.getItem('aw_token') || '';

// Removed static fallback data

let allData      = [];
let statusFilter = 'all';

async function loadValuations() {
  try {
    const res  = await fetch(`${API}/api/valuations?per_page=100`, {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await res.json();
    allData = (data.success && data.data?.items) ? data.data.items : [];
  } catch(e) {
    console.error(e);
    allData = [];
  }
  render();
}

function render() {
  const q   = document.getElementById('vsearch').value.toLowerCase();
  const rows = allData.filter(v => {
    const text = [v.reg_no, v.make, v.model, String(v.id)].join(' ').toLowerCase();
    const stOk = statusFilter === 'all' || (v.status||'').toLowerCase() === statusFilter;
    return stOk && (!q || text.includes(q));
  });

  document.getElementById('showCount').textContent  = rows.length;
  document.getElementById('countBadge').textContent = rows.length + ' records';

  const tbody = document.getElementById('vtbody');
  if (!rows.length) {
    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:32px;color:var(--neutral-400);">No valuations found</td></tr>';
    return;
  }

  tbody.innerHTML = rows.map(v => {
    const d   = v.created_at ? v.created_at.substring(0,10) : '—';
    const st  = v.status || 'Pending';
    const cls = st === 'Approved' ? 'badge-success' : st === 'Rejected' ? 'badge-danger' : 'badge-warning';
    const canEdit = st === 'Pending';
    const canPrint = st === 'Approved';
    return `
      <tr>
        <td class="td-mono">#${v.id}</td>
        <td class="td-mono" style="font-weight:600;">${v.reg_no || '—'}</td>
        <td style="font-weight:600;">${v.make || '—'}</td>
        <td style="color:var(--neutral-500);">${v.model || '—'}</td>
        <td class="td-mono">${v.yom || '—'}</td>
        <td class="td-mono" style="font-weight:700;color:var(--blue-800);">Rs. ${(v.market_value||0).toLocaleString()}</td>
        <td class="td-mono" style="font-size:.78rem;">${d}</td>
        <td><span class="badge ${cls}">${st}</span></td>
        <td>
          <div style="display:flex;gap:4px;">
            <a href="/user/view-valuation?id=${v.id}" class="btn btn-ghost btn-sm" title="View Details" style="padding:4px;">${window.ICONS.eye}</a>
            <a href="/user/add-valuation?edit=${v.id}" class="btn btn-ghost btn-sm" title="Edit"
              style="padding:4px;${!canEdit ? 'opacity:.35;pointer-events:none;' : ''}">${window.ICONS.edit}</a>
            <a href="javascript:void(0)" onclick="window.open('/reports/${v.id}?token=' + encodeURIComponent(localStorage.getItem('aw_token')), '_blank')" class="btn btn-ghost btn-sm" title="Print" style="padding:4px;${st !== 'Approved' ? 'opacity:.35;pointer-events:none;' : ''}">${window.ICONS.printer}</a>
          </div>
        </td>
      </tr>`;
  }).join('');
}

function setStatusFilter(s) {
  statusFilter = s;
  ['all','approved','pending','rejected'].forEach(k => {
    const btn = document.getElementById('fs-' + k);
    if (!btn) return;
    btn.className = 'btn btn-sm ' + (k === s ? 'btn-primary' : 'btn-secondary');
  });
  render();
}
window.setStatusFilter = setStatusFilter;

document.getElementById('vsearch').addEventListener('input', render);

loadValuations();
</script>
