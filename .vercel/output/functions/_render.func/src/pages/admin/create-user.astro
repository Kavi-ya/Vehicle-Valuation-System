---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Icon from '../../components/Icon.astro';
---
<DashboardLayout title="Create User" subtitle="Admin-only — Create new system users" role="admin" activePage="create-user">

  <div class="page-header">
    <h1>Create New User</h1>
    <p>Only administrators can create new user accounts</p>
  </div>

  <div style="max-width:780px;">
    <div class="card">
      <div class="card-header">
        <div class="card-title">
          <div class="icon" style="background:var(--primary-100);color:var(--primary-600);"><Icon name="user" /></div>
          User Account Details
        </div>
        <span class="badge badge-blue"><Icon name="shield" size="12" /> Admin Only</span>
      </div>
      <div class="card-body">
        <form id="createUserForm" onsubmit="handleCreate(event)" style="display:flex;flex-direction:column;gap:22px;">

          <!-- Personal Information -->
          <div>
            <div class="divider-label">Personal Information</div>
            <div class="form-grid" style="grid-template-columns:repeat(2,1fr);">
              <div class="form-group">
                <label>First Name <span class="required">*</span></label>
                <input type="text" class="form-control" name="first_name" placeholder="Enter first name" required />
              </div>
              <div class="form-group">
                <label>Last Name <span class="required">*</span></label>
                <input type="text" class="form-control" name="last_name" placeholder="Enter last name" required />
              </div>
              <div class="form-group">
                <label>Email Address <span class="required">*</span></label>
                <input type="email" class="form-control" name="email" placeholder="user@example.com" required />
              </div>
              <div class="form-group">
                <label>Phone Number</label>
                <input type="tel" class="form-control" name="phone" placeholder="+94 XX XXX XXXX" />
              </div>
            </div>
          </div>

          <!-- Account Credentials -->
          <div>
            <div class="divider-label">Account Credentials</div>
            <div class="form-grid" style="grid-template-columns:repeat(2,1fr);">
              <div class="form-group">
                <label>Username <span class="required">*</span></label>
                <input type="text" class="form-control" name="username" placeholder="Choose a username" required
                  autocomplete="off" />
              </div>
              <div class="form-group">
                <label>Password <span class="required">*</span></label>
                <input type="password" class="form-control" name="password" placeholder="Min 8 characters" required
                  id="pwd" oninput="checkPwd()" />
              </div>
              <div class="form-group">
                <label>Confirm Password <span class="required">*</span></label>
                <input type="password" class="form-control" name="confirm_password"
                  placeholder="Re-enter password" required id="pwd2" oninput="checkPwd()" />
              </div>
              <div class="form-group">
                <label>&nbsp;</label>
                <div id="pwdStrength" style="height:38px;display:flex;align-items:center;gap:8px;">
                  <div style="flex:1;height:4px;background:var(--neutral-200);border-radius:2px;overflow:hidden;">
                    <div id="pwdBar" style="height:100%;width:0%;background:var(--danger-500);transition:all .3s;border-radius:2px;"></div>
                  </div>
                  <span id="pwdLabel" style="font-size:.75rem;color:var(--neutral-400);white-space:nowrap;">Enter password</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Role & Branch -->
          <div>
            <div class="divider-label">Role &amp; Branch Assignment</div>
            <div class="form-grid" style="grid-template-columns:repeat(2,1fr);">
              <div class="form-group">
                <label>User Role <span class="required">*</span></label>
                <select class="form-control" name="role" required>
                  <option value="">— Select Role —</option>
                  <option value="admin">Administrator</option>
                  <option value="valuer">Valuer</option>
                  <option value="dataentry">Data Entry</option>
                </select>
              </div>
              <div class="form-group">
                <label>Assigned Branch <span class="required">*</span></label>
                <select class="form-control" name="branch" required>
                  <option value="">— Select Branch —</option>
                  <option>Monaragala</option>
                  <option>BADULLA</option>
                  <option>BANDARAWELA</option>
                  <option>KENDY</option>
                </select>
              </div>
              <div class="form-group">
                <label>Account Status</label>
                <select class="form-control" name="status">
                  <option value="confirm">Active (Confirmed)</option>
                  <option value="pending">Pending Review</option>
                </select>
              </div>
              <div class="form-group">
                <label>Employee ID</label>
                <input type="text" class="form-control" name="emp_id" placeholder="Optional employee ID" />
              </div>
            </div>
          </div>

          <!-- Permissions -->
          <div>
            <div class="divider-label">Permissions</div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
              {[
                { key:'can_add', label:'Add Valuations', icon:'plus' },
                { key:'can_edit', label:'Edit Valuations', icon:'edit' },
                { key:'can_approve', label:'Approve Reports', icon:'checkcircle' },
                { key:'can_delete', label:'Delete Records', icon:'trash' },
                { key:'can_view_reports', label:'View Reports', icon:'list' },
                { key:'can_manage_users', label:'Manage Users', icon:'users' },
              ].map(p => (
                <label style="display:flex;align-items:center;gap:9px;padding:10px 12px;border:1.5px solid var(--neutral-200);border-radius:9px;cursor:pointer;transition:all .15s;font-weight:400;color:var(--neutral-700);" class="perm-check">
                  <input type="checkbox" name={p.key} style="width:15px;height:15px;accent-color:var(--primary-500);" />
                  <span><Icon name={p.icon} size="14" /></span>
                  <span style="font-size:.82rem;">{p.label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Error/Success -->
          <div id="formMsg" style="display:none;"></div>

          <!-- Actions -->
          <div style="display:flex;gap:10px;padding-top:8px;border-top:1px solid var(--neutral-100);">
            <button type="submit" class="btn btn-primary btn-lg"><Icon name="check" size="16" /> Create User</button>
            <a href="/admin/users" class="btn btn-secondary btn-lg">Cancel</a>
            <button type="button" class="btn btn-ghost btn-lg" onclick="resetForm()"><Icon name="x" size="16" /> Reset</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</DashboardLayout>

<style>
  .perm-check:hover { border-color: var(--primary-300); background: var(--primary-50); }
  .perm-check:has(input:checked) { border-color: var(--primary-400); background: var(--primary-50); }
</style>

<script>
const API = 'http://localhost:8080';
const token = localStorage.getItem('aw_token') || '';
const urlParams = new URLSearchParams(window.location.search);
const editId = urlParams.get('edit');

if (editId) {
  document.querySelector('.page-header h1').textContent = 'Edit User';
  document.querySelector('.page-header p').textContent = 'Update user account details';
  document.querySelector('button[type="submit"]').innerHTML = window.ICONS.check + ' Update User';
  loadUser(editId);
}

async function loadUser(id) {
  try {
    const res = await fetch(`${API}/api/users/${id}`, {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await res.json();
    if (data.success && data.data) {
      const u = data.data;
      const form = document.getElementById('createUserForm');
      form.first_name.value = u.first_name || '';
      form.last_name.value = u.last_name || '';
      form.email.value = u.email || '';
      form.phone.value = u.phone || '';
      form.username.value = u.username || '';
      form.role.value = u.role || '';
      form.branch.value = u.branch || '';
      form.status.value = u.status || 'confirm';
      form.emp_id.value = u.emp_id || '';
      
      form.password.required = false;
      form.confirm_password.required = false;
      form.password.placeholder = 'Leave blank to keep unchanged';
      form.confirm_password.placeholder = 'Leave blank to keep unchanged';
    }
  } catch (err) {
    console.error('Failed to load user', err);
  }
}

window.checkPwd = function() {
  const pwd = document.getElementById('pwd').value;
  const bar = document.getElementById('pwdBar');
  const label = document.getElementById('pwdLabel');
  let strength = 0;
  if (pwd.length >= 8) strength++;
  if (/[A-Z]/.test(pwd)) strength++;
  if (/[0-9]/.test(pwd)) strength++;
  if (/[^a-zA-Z0-9]/.test(pwd)) strength++;
  const colors = ['var(--danger-500)', 'var(--warning-500)', 'var(--warning-500)', 'var(--success-500)'];
  const labels = ['Too weak', 'Fair', 'Good', 'Strong'];
  bar.style.width = (strength * 25) + '%';
  bar.style.background = colors[Math.max(0, strength - 1)] || colors[0];
  label.textContent = pwd.length === 0 ? 'Enter password' : labels[Math.min(strength - 1, 3)] || labels[0];
  label.style.color = colors[Math.max(0, strength - 1)] || 'var(--neutral-400)';
}

window.handleCreate = async function(e) {
  e.preventDefault();
  const form = e.target;
  const p1 = form.password.value;
  const p2 = form.confirm_password.value;
  const msg = document.getElementById('formMsg');

  if (p1 || (!editId)) {
    if (p1 !== p2) {
      msg.innerHTML = '<div class="alert alert-danger">' + window.ICONS.xcircle + ' Passwords do not match.</div>';
      msg.style.display = 'block';
      return;
    }
    if (p1.length < 6) {
      msg.innerHTML = '<div class="alert alert-danger">' + window.ICONS.xcircle + ' Password must be at least 6 characters.</div>';
      msg.style.display = 'block';
      return;
    }
  }

  const payload = {
    first_name: form.first_name.value,
    last_name: form.last_name.value,
    email: form.email.value,
    phone: form.phone.value,
    username: form.username.value,
    role: form.role.value,
    branch: form.branch.value,
    status: form.status.value,
    emp_id: form.emp_id.value,
  };
  
  if (p1) {
    payload.password = p1;
    payload.confirm_password = p2;
  }

  try {
    const url = editId ? `${API}/api/users/${editId}` : `${API}/api/users`;
    const method = editId ? 'PUT' : 'POST';
    
    const res = await fetch(url, {
      method,
      headers: { 
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + token
      },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    
    if (data.success) {
      msg.innerHTML = `<div class="alert alert-success">${window.ICONS.checkcircle} User ${editId ? 'updated' : 'created'} successfully! Redirecting...</div>`;
      msg.style.display = 'block';
      setTimeout(() => window.location.href = '/admin/users', 1500);
    } else {
      msg.innerHTML = `<div class="alert alert-danger">${window.ICONS.xcircle} ${data.message || 'Error occurred'}</div>`;
      msg.style.display = 'block';
    }
  } catch (err) {
    msg.innerHTML = `<div class="alert alert-danger">${window.ICONS.xcircle} Could not connect to server.</div>`;
    msg.style.display = 'block';
  }
}

window.resetForm = function() {
  document.getElementById('createUserForm').reset();
  document.getElementById('pwdBar').style.width = '0%';
  document.getElementById('pwdLabel').textContent = 'Enter password';
  document.getElementById('formMsg').style.display = 'none';
}
</script>
