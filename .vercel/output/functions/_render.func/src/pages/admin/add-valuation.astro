            <div style="font-size:.72rem;color:var(--neutral-400);">Click to select</div>
            <img id={`preview-${slot.n}`} style="display:none;width:100%;height:120px;object-fit:cover;border-radius:8px;margin-top:10px;" alt={`Preview ${slot.label}`} />
            <div id={`fname-${slot.n}`} style="display:none;font-size:.7rem;color:var(--neutral-500);margin-top:6px;word-break:break-all;"></div>
            <input type="file" id={`img${slot.n}`} name={`image${slot.n}`} accept=".jpg,.jpeg,.png,.webp" style="display:none;" onchange={`previewPhoto(${slot.n})`} />
