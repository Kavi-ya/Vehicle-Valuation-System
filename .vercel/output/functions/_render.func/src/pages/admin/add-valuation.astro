    setVal('sel_batteries', v.maint_batteries);
    setVal('sel_body_part', v.spares_body_parts);
    setVal('sel_door', v.spares_doors);
    setVal('sel_engine_part', v.spares_engine_parts);
    setVal('sel_roof', v.spares_roof_type);
    setVal('sel_access_part', v.spares_accessories);
    setVal('txt_gov_policy', v.gov_policy);
    setVal('sel_vat', v.vat ? 'yes' : 'no');
    setVal('sel_branch', v.branch);
    setVal('txt_accident', v.accident);
    setVal('sel_complience_envir2', v.envir_reg);
    setVal('txt_complience_comment', v.comments_2);
    setVal('customer_name', v.customer_name);
    setVal('customer_phone', v.customer_phone);
    if (v.vehicle_type_code) {
      const rb = document.querySelector(`[name="vvehicle_type"][value="${v.vehicle_type_code}"]`);
      if (rb) rb.checked = true;
    }
    if (v.is_rereport !== undefined) {
      const rb = document.querySelector(`[name="rereport"][value="${v.is_rereport ? 'yes' : 'no'}"]`);
      if (rb) rb.checked = true;
    }

    // Handle Choices.js extra options
    if (v.extra_options && window.extraOptChoices) {
      window.extraOptChoices.setChoiceByValue(v.extra_options.split(',').map(s => s.trim()));
    }

    // Load existing images
    if (v.image_paths && Array.isArray(v.image_paths)) {
      v.image_paths.forEach((p, i) => {
        if (p) {
          const n = i + 1;
          const preview = document.getElementById('preview-' + n);
          const fname = document.getElementById('fname-' + n);
          const slot = document.getElementById('slot-' + n);
          const removeBtn = document.getElementById('remove-' + n);
          
          if (preview) {
            const imgSrc = p.startsWith('http') ? p : (p.startsWith('/') ? `${API}${p}` : `${API}/${p}`);
            preview.src = imgSrc;
            preview.style.display = 'block';
            if (fname) {
              fname.textContent = p.split('/').pop() || 'image.jpg';
              fname.style.display = 'block';
            }
            if (slot) {
              slot.style.border = '2px solid var(--primary-500)';
              slot.style.background = '#fff';
            }
            if (removeBtn && mode !== 'view' && mode !== 'print') {
              removeBtn.style.display = 'flex';
            }
          }
        }
      });
    }

    // Disable form if view/print
    if (mode === 'view' || mode === 'print') {
      document.querySelectorAll('input, select, textarea').forEach(el => {
        el.disabled = true;
        el.style.background = 'transparent';
        el.style.border = 'none';
        el.style.color = '#111827';
        el.style.appearance = 'none';
      });
      document.querySelectorAll('.btn').forEach(btn => {
        if (btn.id !== 'submitBtn') btn.style.display = 'none';
      });
      if (mode === 'print') { setTimeout(() => window.print(), 800); }
    }
  } catch(e) {
    console.error('Error loading valuation', e);
  }
}

const initData = async () => {
  const user = JSON.parse(localStorage.getItem('aw_user') || '{}');
  const urlParams = new URLSearchParams(window.location.search);
  const isEdit = !!urlParams.get('edit');
  const isView = !!urlParams.get('view') || !!urlParams.get('print');
  
  if (!isEdit && !isView && user.can_add === false) {
     alert('You do not have permission to add valuations.');
     window.location.href = '/admin/valuations';
     return;
  }
  if (isEdit && user.can_edit === false) {
     alert('You do not have permission to edit valuations.');
     window.location.href = '/admin/valuations';
     return;
  }

  await loadFormOptions();
  await loadExistingValuation(user);
};
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initData);
} else {
  initData();
}

// Convert all text inputs and textareas to UPPERCASE on input
document.addEventListener('input', function(e) {
  if (e.target.tagName === 'TEXTAREA' || (e.target.tagName === 'INPUT' && e.target.type === 'text')) {
    const start = e.target.selectionStart;
    const end = e.target.selectionEnd;
    e.target.value = e.target.value.toUpperCase();
    e.target.setSelectionRange(start, end);
  }
});

const initVehicleLogic = () => {
  // Handle Tyre Type conditional logic for Material Selects
  const tyreTypeSel = document.getElementById('sel_tyre_type');
  const frMatSel = document.getElementById('sel_tyrefr_meterial');
  const reMatSel = document.getElementById('sel_tyrere_meterial');
  const frTypeSel = document.getElementById('sel_tyre_front_type');
  const reTypeSel = document.getElementById('sel_tyre_rear_type');
  
  if (tyreTypeSel && frMatSel && reMatSel) {
    tyreTypeSel.addEventListener('change', (e) => {
      const val = e.target.value;
      if (val === 'Tyre') {
        frMatSel.style.display = 'none';
        reMatSel.style.display = 'none';
        frMatSel.value = '';
        reMatSel.value = '';
      } else {
        frMatSel.style.display = '';
        reMatSel.style.display = '';
      }
      
      if (val === 'Track') {
        if (frTypeSel) frTypeSel.value = 'Right Side Track';
        if (reTypeSel) reTypeSel.value = 'Left Side Track';
      }
    });
    // Let options populate before initial trigger
    setTimeout(() => {
      tyreTypeSel.dispatchEvent(new Event('change'));
    }, 800);
  }
};

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initVehicleLogic);
} else {
  initVehicleLogic();
}
