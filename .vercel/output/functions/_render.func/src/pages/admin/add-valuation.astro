---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Icon from '../../components/Icon.astro';
---
<DashboardLayout title="Add Valuation" subtitle="Multi-step vehicle valuation entry" role="admin" activePage="add-valuation">

  <div class="page-header">
    <h1>Add New Valuation</h1>
    <p>Complete all 5 steps to submit a vehicle valuation</p>
  </div>

  <!-- Step Bar -->
  <div class="step-bar" id="stepBar">
    <div class="step-item active" data-step="1" onclick="goTo(1)">
      <div class="step-num">1</div><span>Vehicle Info</span>
    </div>
    <div class="step-item" data-step="2" onclick="goTo(2)">
      <div class="step-num">2</div><span>Technical</span>
    </div>
    <div class="step-item" data-step="3" onclick="goTo(3)">
      <div class="step-num">3</div><span>Road Test</span>
    </div>
    <div class="step-item" data-step="4" onclick="goTo(4)">
      <div class="step-num">4</div><span>Valuation</span>
    </div>
    <div class="step-item" data-step="5" onclick="goTo(5)">
      <div class="step-num">5</div><span>Photos</span>
    </div>
  </div>

  <!-- STEP 1 -->
  <div class="card" id="step-1">
    <div class="card-header">
      <div class="card-title">
        <div class="icon" style="background:var(--primary-100);color:var(--primary-600);"><Icon name="car" /></div>
        Step 1 - Vehicle Information &amp; Form Options
      </div>
    </div>
    <div class="card-body">
      <div class="divider-label">Opinion &amp; Finance</div>
      <div class="form-grid" style="grid-template-columns:repeat(3,1fr);">
        <div class="form-group">
          <label>Opinion Provided To <span class="required">*</span></label>
          <select class="form-control" name="sel_openion_provider">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Finance Company</label>
          <select class="form-control" name="sel_finance">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Finance Branch</label>
          <select class="form-control" name="sel_finance_branch">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Print Date</label>
          <input type="date" class="form-control" name="txt_pin_date" />
        </div>
        <div class="form-group">
          <label>Date and time of Inspection <span class="required">*</span></label>
          <input type="datetime-local" class="form-control" name="txt_inspection_date" />
        </div>
        <div class="form-group">
          <label>Place of Inspection</label>
          <input type="text" class="form-control" name="txt_inspect_location" placeholder="Location" />
        </div>
        <div class="form-group">
          <label>Yard</label>
          <select class="form-control" name="sel_yard">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Branch</label>
          <select class="form-control" name="sel_branch">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
      </div>

      <div class="divider-label">Vehicle Identification Details</div>
      <div class="form-grid" style="grid-template-columns:repeat(3,1fr);">
        <div class="form-group">
          <label>Chassis No. <span class="required">*</span></label>
          <input type="text" class="form-control" name="txt_chassis_no" placeholder="Chassis number" />
        </div>
        <div class="form-group">
          <label>If converted date</label>
          <input type="date" class="form-control" name="txt_fuelconvert_date" />
        </div>
        <div class="form-group">
          <label>Engine No. <span class="required">*</span></label>
          <input type="text" class="form-control" name="txt_engine_no" placeholder="Engine number" />
        </div>
        <div class="form-group">
          <label>Type</label>
          <input type="text" class="form-control" name="txt_type" placeholder="Type" />
        </div>
        <div class="form-group">
          <label>Registration No. <span class="required">*</span></label>
          <input type="text" class="form-control" name="txt_reg_no" placeholder="e.g. WP BIA-5292" />
        </div>
        <div class="form-group">
          <label>Date of Import</label>
          <input type="date" class="form-control" name="txt_import_date" />
        </div>
        <div class="form-group">
          <label>Classification</label>
          <select class="form-control" name="sel_vehicle_type">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Date of Clearing</label>
          <input type="date" class="form-control" name="txt_clear_date" />
        </div>
        <div class="form-group">
          <label>Make <span class="required">*</span></label>
          <select class="form-control" name="sel_make">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Country of Origin</label>
          <select class="form-control" name="sel_country_origin">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Model <span class="required">*</span></label>
          <input type="text" class="form-control" name="txt_model" placeholder="e.g. Corolla" />
        </div>
        <div class="form-group">
          <label>Country of Used</label>
          <select class="form-control" name="sel_country_used">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Engine Capacity (cc)</label>
          <input type="text" class="form-control" name="txt_engine_capacity" placeholder="e.g. 1500" />
        </div>
        <div class="form-group">
          <label>Year of Manufacture</label>
          <input type="text" class="form-control" name="sel_yom" placeholder="e.g. 2019" maxlength="4" />
        </div>
        <div class="form-group">
          <label>Switch Key No</label>
          <input type="text" class="form-control" name="txt_switchkey_no" />
        </div>
        <div class="form-group">
          <label>Type of Fuel</label>
          <select class="form-control" name="sel_fuel_type">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Current Owner</label>
          <input type="text" class="form-control" name="txt_curnowner" />
        </div>
        <div class="form-group">
          <label>Body Color</label>
          <select class="form-control" name="sel_color">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Meter Reading</label>
          <div style="display:flex;gap:5px;">
            <input type="text" class="form-control" name="txt_meter" placeholder="e.g. 85000" />
            <select class="form-control no-choice" name="sel_analog" style="width:80px;">
              <option value="KM">KM</option>
              <option value="MI">MI</option>
              <option value="HRS">HRS</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>No of Previous Owners</label>
          <input type="text" class="form-control" name="txt_preowner" />
        </div>
        <div class="form-group">
          <label>Just Low</label>
          <select class="form-control" name="sel_justlow">
            <option value="" disabled selected hidden>- Select -</option>
            <option value="Yes">Yes</option>
            <option value="No">No</option>
          </select>
        </div>
        <div class="form-group">
          <label>Importer</label>
          <input type="text" class="form-control" name="txt_importer" />
        </div>
        <div class="form-group">
          <label>4x4 Wheel Drive</label>
          <select class="form-control" name="sel_4wd">
            <option value="0">No</option>
            <option value="1">Yes</option>
          </select>
        </div>
        <div class="form-group">
          <label>Seating Capacity</label>
          <select class="form-control" name="sel_seat">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Fuel System</label>
          <select class="form-control" name="sel_fuel_sys">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Date of Registration</label>
          <input type="date" class="form-control" name="txt_date_reg" />
        </div>
        <div class="form-group">
          <label>Gross Weight (kg)</label>
          <input type="text" class="form-control" name="txt_grosweight" placeholder="e.g. 2500" />
        </div>
        <div class="form-group">
          <label>Unladen Weight (kg)</label>
          <input type="text" class="form-control" name="txt_unweight" placeholder="e.g. 1500" />
        </div>
        <div class="form-group">
          <label>Type of Body</label>
          <select class="form-control" name="sel_body_type">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>If dual purpose</label>
          <input type="text" class="form-control" name="txt_dual" />
        </div>
      </div>



      <div class="form-group full" style="margin-top:8px;">
        <label>Extra Options / Remarks</label>
        <div style="margin-bottom:8px;">
          <select id="extraOptSelect" name="sel_extra[]" class="form-control" multiple>
          </select>
        </div>
      </div>


      <div class="divider-label">Compliance</div>
      <div class="form-grid" style="grid-template-columns:repeat(2,1fr);">
        <div class="form-group">
          <label>Compliance of above (1.0-1.25) with CR</label>
          <select class="form-control" name="sel_complience_envir">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>If No Comments</label>
          <textarea class="form-control" name="txt_comments" placeholder="Comments if any..." rows="2"></textarea>
        </div>
      </div>

      <div style="display:flex;justify-content:flex-end;margin-top:20px;">
        <button class="btn btn-primary btn-lg" onclick="goTo(2)">Next: Technical →</button>
      </div>
    </div>
  </div>

  <!-- STEP 2 -->
  <div class="card" id="step-2" style="display:none;">
    <div class="card-header">
      <div class="card-title">
        <div class="icon" style="background:var(--warning-100);color:#d97706;"><Icon name="wrench" /></div>
        Step 2 - Technical Evaluation
      </div>
    </div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:repeat(2, 1fr);column-gap:32px;">
        {[
          { label:'Gear box', fields:[{name:'sel_transmission'},{name:'sel_gearbox_con', label:'Gear selection'}]},
          { label:'Electrical System', fields:[{name:'sel_starter'},{name:'sel_starter_con'}]},
          { label:'Clutch', fields:[{name:'sel_clutch'},{name:'sel_clutch_con'}]},
          { label:'Wiper', fields:[{name:'sel_wiper_type'},{name:'sel_wiper_con'}]},
          { label:'Shafting', fields:[{name:'sel_shaft_type'},{name:'sel_shaft_con'}]},
          { label:'Differential', fields:[{name:'sel_differential'},{name:'sel_differential_con'}]},
          { label:'Horn', fields:[{name:'sel_horn_con'},{}]},
          { label:'Lights', fields:[{name:'sel_light_con'},{}]},
          { label:'Meter', fields:[{name:'sel_meter_con'},{}]},
          { label:'Alternator', fields:[{name:'sel_alternator_con'},{}]},
          { label:'Foot Brakes', fields:[{name:'sel_foot_brake'},{name:'sel_ftbrake_con'}]},
          { label:'Parking Brakes', fields:[{},{name:'sel_pkbrake_con'}]},
          { label:'Front Suspen.', fields:[{name:'sel_suspen_fr_type'},{name:'sel_suspen_fr_con'}]},
          { label:'Rear Suspen.', fields:[{name:'sel_suspen_re_type'},{name:'sel_suspen_re_con'}]},
          { label:'Steering', fields:[{name:'sel_steering'},{name:'sel_steering_con'}]},
        ].map(row => (
          <div style="display:grid;grid-template-columns:130px 1fr 1.5fr;align-items:center;gap:8px;padding:10px 0;border-bottom:1px solid var(--neutral-100);">
            <div style="font-size:.83rem;font-weight:500;color:var(--neutral-700);">{row.label}</div>
            {row.fields.map(f => (
              f.name ? (
                <div class={f.label ? "choices-flex-container" : ""} style={f.label ? "display:flex;align-items:center;gap:8px;" : "display:block;"}>
                  {f.label && <div style="font-size:.83rem;font-weight:500;color:var(--neutral-700);white-space:nowrap;">{f.label}</div>}
                  <select class="form-control" name={f.name} style={f.label ? "flex:1;" : ""}>
                    <option value="" disabled selected hidden>- Select -</option>
                  </select>
                </div>
              ) : <div></div>
            ))}
          </div>
        ))}
      </div>

      <div class="divider-label" style="margin-top:16px;">Engine</div>
      <div class="form-grid" style="grid-template-columns:repeat(3,1fr);">
        <div class="form-group">
          <label>Engine Condition</label>
          <select class="form-control" name="sel_engine_con">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Engine Status</label>
          <select class="form-control" name="sel_engine_status">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Overhaul Done On</label>
          <input type="text" class="form-control" name="txt_engine_overhaul" placeholder="e.g. 2021" />
        </div>
        <div class="form-group">
          <label>Engine Replaced On</label>
          <input type="date" class="form-control" name="txt_engine_replace" />
        </div>

        <div class="form-group">
          <label>Chassis Condition</label>
          <select class="form-control" name="sel_chassis_con">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
      </div>

      <div class="divider-label">Tyre &amp; Wheel Specifications</div>
      <div class="form-grid-2">
        <div class="form-group">
          <label>Tyre Type</label>
          <select name="sel_tyre_type" id="sel_tyre_type" class="form-control">
            <option value="Tyre" selected>Tyre</option>
          </select>
        </div>
        <div class="form-group">
          <label>Wheel Type</label>
          <select name="sel_wheel_type" id="sel_wheel_type" class="form-control">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
      </div>

      <div class="form-group full" style="margin-top:16px;">
        <label>Front Tyres</label>
        <div style="display:flex; gap:10px; flex-wrap:wrap; background:rgba(0,0,0,0.02); padding:12px; border-radius:8px; border:1px solid var(--neutral-200);">
          <select name="sel_tyre_front_type" id="sel_tyre_front_type" class="form-control no-choice" style="width:140px;">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
          <select name="sel_tyrefr_meterial" id="sel_tyrefr_meterial" class="form-control no-choice" style="width:120px;">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
          <input name="txt_fr_size" id="txt_fr_size" class="form-control" placeholder="Size" style="width:100px;">
          <input name="txt_fr_wheel" id="txt_fr_wheel" class="form-control" placeholder="Wheel" style="width:100px;">
          <input name="txt_fr1" id="txt_fr1" class="form-control" placeholder="W1" style="width:60px;">
          <input name="txt_fr2" id="txt_fr2" class="form-control" placeholder="W2" style="width:60px;">
          <input name="txt_fr3" id="txt_fr3" class="form-control" placeholder="W3" style="width:60px;">
          <input name="txt_fr4" id="txt_fr4" class="form-control" placeholder="W4" style="width:60px;">
        </div>
      </div>

      <div class="form-group full" style="margin-top:8px;">
        <label>Rear Tyres</label>
        <div style="display:flex; gap:10px; flex-wrap:wrap; background:rgba(0,0,0,0.02); padding:12px; border-radius:8px; border:1px solid var(--neutral-200);">
          <select name="sel_tyre_rear_type" id="sel_tyre_rear_type" class="form-control no-choice" style="width:140px;">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
          <select name="sel_tyrere_meterial" id="sel_tyrere_meterial" class="form-control no-choice" style="width:120px;">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
          <input name="txt_re_size" id="txt_re_size" class="form-control" placeholder="Size" style="width:100px;">
          <input name="txt_re_wheel" id="txt_re_wheel" class="form-control" placeholder="Wheel" style="width:100px;">
          <input name="txt_re1" id="txt_re1" class="form-control" placeholder="W1" style="width:60px;">
          <input name="txt_re2" id="txt_re2" class="form-control" placeholder="W2" style="width:60px;">
          <input name="txt_re3" id="txt_re3" class="form-control" placeholder="W3" style="width:60px;">
          <input name="txt_re4" id="txt_re4" class="form-control" placeholder="W4" style="width:60px;">
          <input name="txt_re5" id="txt_re5" class="form-control" placeholder="W5" style="width:60px;">
          <input name="txt_re6" id="txt_re6" class="form-control" placeholder="W6" style="width:60px;">
          <input name="txt_re7" id="txt_re7" class="form-control" placeholder="W7" style="width:60px;">
          <input name="txt_re8" id="txt_re8" class="form-control" placeholder="W8" style="width:60px;">
        </div>
      </div>

      <div class="form-group full" style="margin-top:8px;">
        <label>Spare Tyres</label>
        <div style="display:flex; gap:10px; flex-wrap:wrap; background:rgba(0,0,0,0.02); padding:12px; border-radius:8px; border:1px solid var(--neutral-200);">
          <input name="txt_sp_size" id="txt_sp_size" class="form-control" placeholder="Size" style="width:100px;">
          <input name="txt_sp_wheel" id="txt_sp_wheel" class="form-control" placeholder="Wheel" style="width:100px;">
          <input name="txt_sp1" id="txt_sp1" class="form-control" placeholder="W1" style="width:60px;">
          <input name="txt_sp2" id="txt_sp2" class="form-control" placeholder="W2" style="width:60px;">
        </div>
      </div>

      <div class="form-group" style="margin-top:12px;">
        <label>Special Features</label>
        <textarea class="form-control" name="txt_special_feature" placeholder="List any special features..."></textarea>
      </div>

      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px;">
        <button class="btn btn-secondary btn-lg" onclick="goTo(1)">← Previous</button>
        <button class="btn btn-primary btn-lg" onclick="goTo(3)">Next: Road Test →</button>
      </div>
    </div>
  </div>

  <!-- STEP 3 -->
  <div class="card" id="step-3" style="display:none;">
    <div class="card-header">
      <div class="card-title">
        <div class="icon" style="background:var(--info-100);color:#0891b2;"><Icon name="trending" /></div>
        Step 3 - Road Test &amp; Condition
      </div>
    </div>
    <div class="card-body">
      <div class="form-grid" style="grid-template-columns:repeat(2,1fr);">
        <div class="form-group">
          <label>Power Shutters</label>
          <select class="form-control" name="sel_pwshutter_con">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Power Mirror</label>
          <select class="form-control" name="sel_pwmirror_con">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>AC Type</label>
          <select class="form-control" name="sel_air_type">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>AC Condition</label>
          <select class="form-control" name="sel_ac_con">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>


        <div class="form-group">
          <label>Road test done on</label>
          <input type="date" class="form-control" name="txt_road_test_done_on" />
        </div>

        <div class="form-group">
          <label>Fuel Consumption (km/L)</label>
          <input type="text" class="form-control" name="txt_fuel_consum" placeholder="e.g. 12" />
        </div>

        <div class="form-group">
          <label>If Not Comments</label>
          <textarea class="form-control" name="txt_if_not_comments"></textarea>
        </div>
      </div>
      <div class="form-grid" style="grid-template-columns:repeat(2,1fr);margin-top:8px;">
        <div class="form-group">
          <label>Need within a year</label>
          <textarea class="form-control" name="txt_need_repair" placeholder="List repairs required..."></textarea>
        </div>
        <div class="form-group">
          <label>Body parts replaced</label>
          <textarea class="form-control" name="txt_body_repair" placeholder="Body repair details..."></textarea>
        </div>
        <div class="form-group">
          <label>Accidents</label>
          <textarea class="form-control" name="txt_accident" placeholder="Accident details if any..."></textarea>
        </div>
        <div class="form-group">
          <label>Write off by insurers</label>
          <textarea class="form-control" name="txt_insurers" placeholder=""></textarea>
        </div>
        <div class="form-group">
          <label>Comments</label>
          <textarea class="form-control" name="txt_repair_comment" placeholder=""></textarea>
        </div>
      </div>

      <div class="divider-label" style="margin-top:16px;">Maintenance</div>
      <div class="form-grid" style="grid-template-columns:repeat(2,1fr);">
        <div class="form-group">
          <label>Mechanical</label>
          <select class="form-control" name="sel_mechanical_maint">
             <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>

        <div class="form-group">
          <label>Batteries</label>
          <select class="form-control" name="sel_batteries">
             <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Condition</label>
          <select class="form-control" name="sel_vehicle_con">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Body Maintenance</label>
          <select class="form-control" name="sel_body_maint">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Interior Trim</label>
          <select class="form-control" name="sel_intertrim">
            <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Internal Trim condition</label>
          <select class="form-control" name="sel_intertrim_con">
             <option value="" disabled selected hidden>- Select -</option>
          </select>
        </div>
        <div class="form-group">
          <label>Impact on government policies</label>
          <select class="form-control" name="txt_gov_policy">
            <option value="" disabled selected hidden>- Select -</option>
            <option value="0">No</option>
            <option value="1">Yes</option>
          </select>
        </div>
        <div class="form-group">
          <label>Compliance with environment regulation</label>
          <select class="form-control" name="sel_complience_envir2">
            <option value="" disabled selected hidden>- Select -</option>
            <option value="0">No</option>
            <option value="1">Yes</option>
          </select>
        </div>
