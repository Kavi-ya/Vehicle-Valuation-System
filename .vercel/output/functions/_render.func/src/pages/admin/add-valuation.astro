<script>
const API = 'http://localhost:8080';
let currentStep = 1;
let createdValuationId = null;


window.goTo = function(step) {
  document.querySelectorAll('[id^="step-"]').forEach(el => el.style.display = 'none');
  document.getElementById('step-' + step).style.display = '';
  document.querySelectorAll('.step-item').forEach(el => {
    const s = parseInt(el.dataset.step);
    el.className = 'step-item' + (s === step ? ' active' : s < step ? ' done' : '');
    const num = el.querySelector('.step-num');
    if (s < step) num.textContent = '✓';
    else num.textContent = s;
  });
  currentStep = step;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

window.calcTotal = function() {}

window.croppedImages = window.croppedImages || {};
let currentCropper = null;
let currentCropSlot = null;
let currentCropFile = null;

window.removePhoto = function(n) {
  const fileInput = document.getElementById('img' + n);
  if (fileInput) fileInput.value = '';
  
  if (window.croppedImages && window.croppedImages[n]) {
    delete window.croppedImages[n];
  }
  
  const preview = document.getElementById('preview-' + n);
  const fname = document.getElementById('fname-' + n);
  const slot = document.getElementById('slot-' + n);
  const removeBtn = document.getElementById('remove-' + n);
  
  if (preview) { preview.src = ''; preview.style.display = 'none'; }
  if (fname) { fname.textContent = ''; fname.style.display = 'none'; }
  if (slot) {
    slot.style.border = '2px dashed var(--neutral-200)';
    slot.style.background = 'var(--neutral-50)';
  }
  if (removeBtn) removeBtn.style.display = 'none';
}

window.previewPhoto = function(n) {
  const fileInput = document.getElementById('img' + n);
  const file = fileInput.files[0];
  if (!file) return;
  
  currentCropSlot = n;
  currentCropFile = file;

  const url = URL.createObjectURL(file);
  const image = document.getElementById('cropperImage');
  image.src = url;
  
  document.getElementById('cropperModal').style.display = 'flex';
  
  if (currentCropper) {
    currentCropper.destroy();
  }
  
  currentCropper = new Cropper(image, {
    viewMode: 1,
    autoCropArea: 1,
    background: false,
    zoomable: true,
  });
}

function closeCropper() {
  document.getElementById('cropperModal').style.display = 'none';
  if (currentCropper) {
    currentCropper.destroy();
    currentCropper = null;
  }
  if (currentCropSlot) {
     const fileInput = document.getElementById('img' + currentCropSlot);
     if(fileInput) fileInput.value = '';
  }
}

document.getElementById('cropperCancelBtn').addEventListener('click', closeCropper);
document.getElementById('cropperCancelBtn2').addEventListener('click', closeCropper);

document.getElementById('cropperSaveBtn').addEventListener('click', function() {
  if (!currentCropper || !currentCropSlot) return;
  
  const canvas = currentCropper.getCroppedCanvas();
  if (!canvas) return;

  canvas.toBlob(function(blob) {
    const n = currentCropSlot;
    window.croppedImages[n] = blob;
    
    const preview = document.getElementById('preview-' + n);
    const fname   = document.getElementById('fname-' + n);
    const slot    = document.getElementById('slot-' + n);
    
    preview.src = URL.createObjectURL(blob);
    preview.style.display = 'block';
    fname.textContent = currentCropFile.name + ' (Cropped)';
    fname.style.display = 'block';
    slot.style.border = '2px solid var(--primary-500)';
    slot.style.background = '#fff';
    
    const removeBtn = document.getElementById('remove-' + n);
    if (removeBtn) removeBtn.style.display = 'flex';
    
    closeCropper();
  }, 'image/jpeg', 0.9);
});

window.showMsg = function(type, text, id) {
  const msg = document.getElementById(id || 'submitMsg5');
  const color = type === 'success' ? '#16a34a' : '#dc2626';
  const bg    = type === 'success' ? '#f0fdf4'  : '#fef2f2';
  const border= type === 'success' ? '#bbf7d0'  : '#fecaca';
  msg.innerHTML = `<div style="padding:14px 18px;border-radius:8px;background:${bg};border:1px solid ${border};color:${color};font-weight:500;">${text}</div>`;
  msg.style.display = 'block';
}

window.submitValuation = async function() {
  const btn = document.getElementById('submitBtn');
  const msg = document.getElementById('submitMsg5');
  btn.disabled = true;
  btn.textContent = '⏳ Submitting...';
  msg.style.display = 'none';

  const g = id => document.querySelector(`[name="${id}"]`)?.value || '';

  const payload = {
    reg_no:           g('txt_reg_no'),
    chassis_no:       g('txt_chassis_no'),
    engine_no:        g('txt_engine_no'),
    make:             g('sel_make'),
    model:            g('txt_model'),
    yom:              parseInt(g('sel_yom')) || 0,
    country_origin:   g('sel_country_origin'),
    country_used:     g('sel_country_used'),
    engine_capacity:  g('txt_engine_capacity'),
    fuel_type:        g('sel_fuel_type'),
    body_color:       g('sel_color'),
    meter_reading:    g('txt_meter'),
    meter_unit:       g('sel_analog'),
    current_owner:    g('txt_curnowner'),
    seating_cap:      parseInt(g('sel_seat')) || 0,
    transmission:     g('sel_transmission'),
    gearbox_con:      g('sel_gearbox_con'),
    engine_con:       g('sel_engine_con'),
    engine_status:    g('sel_engine_status'),
    overhaul_done:    g('txt_engine_overhaul'),
    body_con:         g('sel_body_con'),
    chassis_con:      g('sel_chassis_con'),
    vehicle_con:      g('sel_vehicle_con'),
    vehicle_type:     g('sel_vehicle_type'),
    body_type:        g('sel_body_type'),
    air_type:         g('sel_air_type'),
    ac_con:           g('sel_ac_con'),
    steering:         g('sel_steering'),
    steering_con:     g('sel_steering_con'),
    fuel_system:      g('sel_fuel_sys'),
    road_test_done_on: g('txt_road_test_done_on'),
    if_not_comments:  g('txt_if_not_comments'),

    differential_type: g('sel_differential'),
    differential_con:  g('sel_differential_con'),
    light_con:         g('sel_light_con'),
    meter_con:         g('sel_meter_con'),
    alternator_con:    g('sel_alternator_con'),
    starter_type:      g('sel_starter'),
    starter_con:       g('sel_starter_con'),
    clutch_type:       g('sel_clutch'),
    clutch_con:        g('sel_clutch_con'),
    wiper_type:        g('sel_wiper_type'),
    wiper_con:         g('sel_wiper_con'),
    shaft_type:        g('sel_shaft_type'),
    shaft_con:         g('sel_shaft_con'),
    horn_con:          g('sel_horn_con'),
    foot_brake_type:   g('sel_foot_brake'),
    foot_brake_con:    g('sel_ftbrake_con'),
    parking_brake_con: g('sel_pkbrake_con'),
    suspen_fr_type:    g('sel_suspen_fr_type'),
    suspen_fr_con:     g('sel_suspen_fr_con'),
    suspen_re_type:    g('sel_suspen_re_type'),
    suspen_re_con:     g('sel_suspen_re_con'),
    pw_shutter_con:    g('sel_pwshutter_con'),
    pw_mirror_con:     g('sel_pwmirror_con'),
    body_maint:        g('sel_body_maint'),
    inter_trim:        g('sel_intertrim'),
    test_type:         g('sel_test_type'),
    complience_envir:  g('sel_complience_envir'),
    tyre_type:         g('sel_tyre_type'),
    wheel_type:        g('sel_wheel_type'),
    tyre_front_type:   g('sel_tyre_front_type'),
    tyrefr_meterial:   g('sel_tyrefr_meterial'),
    tyre_rear_type:    g('sel_tyre_rear_type'),
    tyrere_meterial:   g('sel_tyrere_meterial'),
    fuel_consumption: g('txt_fuel_consum'),
    market_value:     parseFloat(g('txt_market_value').replace(/[^0-9.]/g, '')) || 0,
    forced_value:     parseFloat(g('txt_forced_value').replace(/[^0-9.]/g, '')) || 0,
    val_amount:       parseFloat(g('txt_value_amount').replace(/[^0-9.]/g, '')) || 0,
    vat:              g('sel_vat') === 'yes',
    branch:           g('sel_branch'),
    inspection_date:  g('txt_inspection_date'),
    pin_date:         g('txt_pin_date'),
    finance_company:  g('sel_finance'),
    finance_branch:   g('sel_finance_branch'),
    opinion_to:       g('sel_openion_provider'),
    yard:             g('sel_yard'),
    inspect_location: g('txt_inspect_location'),
    test_comment:     g('txt_test_comment'),
    special_feature:  g('txt_special_feature'),
    need_repair:      g('txt_need_repair'),
    body_repair:      g('txt_body_repair'),
    accident:         g('txt_accident'),
    envir_reg:         g('sel_complience_envir2'),
    comments_2:        g('txt_complience_comment'),
    extra_options:    Array.from(document.querySelectorAll('[name="sel_extra[]"] option:checked')).map(el => el.value).join(', '),
    need_within_year:  g('txt_need_repair'),
    body_parts_replaced: g('txt_body_repair'),
    write_off:         g('txt_insurers'),
    comments_1:        g('txt_repair_comment'),
    maint_mechanical:  g('sel_mechanical_maint'),
    inter_trim_con:    g('sel_intertrim_con'),
    maint_batteries:   g('sel_batteries'),
    spares_body_parts: g('sel_body_part'),
    spares_body_type:  g('sel_body_type'),
    spares_doors:      g('sel_door'),
    spares_engine_parts: g('sel_engine_part'),
    spares_roof_type:  g('sel_roof'),
    spares_accessories: g('sel_access_part'),
    gov_policy:         g('txt_gov_policy'),
    status:             'Pending',
    image_paths:      ['','','','',''],
  };

  if (!payload.reg_no || !payload.make) {
    showMsg('error', '✗ Registration number and make are required (Step 1).');
    btn.disabled = false;
    btn.textContent = 'Submit Valuation';
    return;
  }

  try {
    const token = localStorage.getItem('aw_token') || '';
    const urlParams = new URLSearchParams(window.location.search);
    const editId = urlParams.get('edit');
    const endpoint = editId ? `${API}/api/valuations/${editId}` : `${API}/api/valuations`;
    const method = editId ? 'PUT' : 'POST';

    const res = await fetch(endpoint, {
      method,
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify(payload),
    });
    const data = await res.json();
    if (!data.success) throw new Error(data.message || 'Submission failed');

    createdValuationId = editId || data.data?.id;

    // Upload images if any selected
    const fd = new FormData();
    let hasImages = false;
    for (let i = 1; i <= 5; i++) {
      let file = (window.croppedImages && window.croppedImages[i]) ? window.croppedImages[i] : null;
      if (!file) {
        file = document.getElementById('img' + i)?.files[0];
      }
      if (file) { 
        fd.append('image' + i, file, file instanceof Blob && !file.name ? `image${i}.jpg` : file.name); 
        hasImages = true; 
      }
    }
    if (hasImages && createdValuationId) {
      await fetch(`${API}/api/valuations/${createdValuationId}/images`, {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token },
        body: fd,
      });
    }

    showMsg('success', `✓ Valuation #${createdValuationId} ${editId ? 'updated' : 'submitted'}! Redirecting…`);
    setTimeout(() => window.location.href = '/admin/valuations', 2000);
  } catch (e) {
    showMsg('error', '✗ ' + e.message);
    btn.disabled = false;
    btn.textContent = 'Submit Valuation';
  }
}

