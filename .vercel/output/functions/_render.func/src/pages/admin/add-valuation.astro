      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;" id="photoGrid">
        {[
          {n:1, label:'Chassis Number',  icon:'Chassis.svg'},
          {n:2, label:'Engine Number',   icon:'Engine.svg'},
          {n:3, label:'Speedometer',     icon:'Speedometer.svg'},
