async function loadFormOptions() {
  try {
    const token = localStorage.getItem('aw_token');
    const res = await fetch(`${API}/api/options`, { headers: { 'Authorization': 'Bearer ' + token }});
    if (!res.ok) return;
    const json = await res.json();
    const allOptions = json.data || [];

    // Populate Extra Options select
    const extraSel = document.getElementById('extraOptSelect');
    if (extraSel) {
      userExtraOptions.sort().forEach(opt => {
        const o = document.createElement('option');
        o.value = opt;
        o.textContent = opt;
        extraSel.appendChild(o);
      });
    }

    // Group options by type
    const grouped = {};
    for (const opt of allOptions) {
      const typeKey = String(opt.option_type || '').trim();
      if (!typeKey) continue;
      if (!grouped[typeKey]) grouped[typeKey] = [];
      grouped[typeKey].push(opt);
    }

    // Sort each group
    Object.keys(grouped).forEach(k => grouped[k].sort((a,b) => (a.sort_order||0) - (b.sort_order||0)));

    // Populate dropdowns dynamically
    const allSelectsToPopulate = document.querySelectorAll('select.form-control:not(#extraOptSelect):not(.no-choice)');
    let popCount = 0;
    allSelectsToPopulate.forEach(sel => {
      const name = String(sel.getAttribute('name') || '').trim();
      if (!name) return;
      const fld = mapOptionsToSelects[name] || name;
      const list = grouped[fld] || grouped[name];
      if (list && list.length > 0) {
        if (sel.choicesInstance) {
          const choicesArr = list.map(opt => ({
            value: opt.value,
            label: (opt.label || opt.value) === 'Dismentaled' ? 'Dismantled' : (opt.label || opt.value)
          }));
          choicesArr.unshift({
            value: '',
            label: '- Select -',
            selected: true,
            disabled: true,
            placeholder: true
          });
          sel.choicesInstance.clearChoices();
          sel.choicesInstance.setChoices(choicesArr, 'value', 'label', true);
        } else {
          sel.innerHTML = '<option value="" disabled selected hidden>- Select -</option>';
          list.forEach(opt => {
            const o = document.createElement('option');
            o.value = opt.value;
            let displayLabel = opt.label || opt.value;
            if (displayLabel === 'Dismentaled') displayLabel = 'Dismantled';
            o.textContent = displayLabel;
            sel.appendChild(o);
          });
        }
        popCount++;
      }
    });

    if (popCount === 0 && allOptions.length > 0) {
      document.body.insertAdjacentHTML('afterbegin', '<div style="background:red;color:white;padding:15px;position:fixed;top:0;left:0;width:100%;z-index:99999;">ERROR: API returned ' + allOptions.length + ' options but none matched the HTML fields.</div>');
    }

    // Initialize Choices.js on Extra Options
    const extraSelEl = document.getElementById('extraOptSelect');
    if (extraSelEl && !extraSelEl.hasAttribute('data-choice')) {
      window.extraOptChoices = new Choices(extraSelEl, {
        searchEnabled: true,
        removeItemButton: true,
        shouldSort: false
      });
    }

    // Initialize Choices.js on all other selects to force dropdown downwards
    const allSelects = document.querySelectorAll('select.form-control:not(#extraOptSelect):not(.no-choice)');
    allSelects.forEach(sel => {
      if (!sel.hasAttribute('data-choice')) {
        const choiceInst = new Choices(sel, {
          searchEnabled: true,
          itemSelectText: '',
          shouldSort: false,
          placeholder: true,
          removeItemButton: true,
          placeholderValue: '- Select -'
        });
        sel.choicesInstance = choiceInst;
      }
    });

  } catch(e) {
    console.error('Error loading form options', e);
    document.body.insertAdjacentHTML('afterbegin', '<div style="background:red;color:white;padding:15px;position:fixed;top:0;left:0;width:100%;z-index:99999;">JS ERROR in loadFormOptions: ' + e.message + '</div>');
  }
}

async function loadExistingValuation(user) {
  const urlParams = new URLSearchParams(window.location.search);
  const vId = urlParams.get('edit') || urlParams.get('view') || urlParams.get('print');
  if (!vId) return;

  let mode = urlParams.get('edit') ? 'edit' : urlParams.get('print') ? 'print' : 'view';

  try {
    const token = localStorage.getItem('aw_token') || '';
    const res = await fetch(`${API}/api/valuations/${vId}`, { headers: { 'Authorization': 'Bearer ' + token }});
    const data = await res.json();
    if (!data.success || !data.data) return;

    const v = data.data;

    if (mode === 'edit') {
      if (user && user.role !== 'admin' && v.status === 'Approved') {
        alert('Approved valuations cannot be edited.');
        window.location.href = '/admin/valuations';
        return;
      }
      document.querySelector('.page-header h1').textContent = `Edit Valuation #${vId}`;
      const sb = document.getElementById('submitBtn');
      if (sb) sb.textContent = 'Update Valuation';
    } else {
      document.querySelector('.page-header h1').textContent = `Valuation Report #${vId}`;
      const sb = document.getElementById('submitBtn');
      if (sb) sb.style.display = 'none';
    }

    const setVal = (name, val) => {
      const el = document.querySelector(`[name="${name}"]`);
      if (el) {
        if (el.type === 'checkbox' || el.type === 'radio') {
          if (el.value === String(val)) el.checked = true;
        } else {
          el.value = val || '';
          if (el.choicesInstance) {
            el.choicesInstance.setChoiceByValue(val || '');
          }
        }
      }
    };

    setVal('txt_reg_no', v.reg_no);
    setVal('txt_chassis_no', v.chassis_no);
    setVal('txt_engine_no', v.engine_no);
    setVal('sel_make', v.make);
    setVal('txt_model', v.model);
    setVal('sel_yom', v.yom);
    setVal('sel_country_origin', v.country_origin);
    setVal('sel_country_used', v.country_used);
    setVal('txt_engine_capacity', v.engine_capacity);
    setVal('sel_fuel_type', v.fuel_type);
    setVal('sel_color', v.body_color);
    setVal('txt_meter', v.meter_reading);
    setVal('sel_analog', v.meter_unit || 'KM');
    setVal('txt_curnowner', v.current_owner);
    setVal('sel_seat', v.seating_cap);
    setVal('sel_transmission', v.transmission);
    setVal('sel_gearbox_con', v.gearbox_con);
    setVal('sel_engine_con', v.engine_con);
    setVal('sel_engine_status', v.engine_status);
    setVal('txt_engine_overhaul', v.overhaul_done);
    setVal('sel_body_con', v.body_con);
    setVal('sel_chassis_con', v.chassis_con);
    setVal('sel_vehicle_con', v.vehicle_con);
    setVal('sel_vehicle_type', v.vehicle_type);
    setVal('sel_body_type', v.body_type);
    setVal('sel_air_type', v.air_type);
    setVal('sel_ac_con', v.ac_con);
    setVal('sel_steering', v.steering);
    setVal('sel_steering_con', v.steering_con);
    setVal('sel_fuel_sys', v.fuel_system);

    setVal('sel_differential', v.differential_type);
    setVal('sel_differential_con', v.differential_con);
    setVal('sel_light_con', v.light_con);
    setVal('sel_meter_con', v.meter_con);
    setVal('sel_alternator_con', v.alternator_con);
    setVal('sel_starter', v.starter_type);
    setVal('sel_starter_con', v.starter_con);
    setVal('sel_clutch', v.clutch_type);
    setVal('sel_clutch_con', v.clutch_con);
    setVal('sel_wiper_type', v.wiper_type);
    setVal('sel_wiper_con', v.wiper_con);
    setVal('sel_shaft_type', v.shaft_type);
    setVal('sel_shaft_con', v.shaft_con);
    setVal('sel_horn_con', v.horn_con);
