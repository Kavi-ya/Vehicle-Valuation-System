            class="photo-slot"
            id={`slot-${slot.n}`}
            style="position:relative;border:2px dashed var(--neutral-200);border-radius:12px;padding:16px;text-align:center;cursor:pointer;transition:all .2s;background:var(--neutral-50);"
            onclick={`if(event.target.tagName !== 'BUTTON') document.getElementById('img${slot.n}').click()`}
          >
            <button id={`remove-${slot.n}`} type="button" style="display:none;position:absolute;top:8px;right:8px;background:var(--danger-500, #ef4444);color:white;border:none;border-radius:50%;width:24px;height:24px;cursor:pointer;z-index:10;align-items:center;justify-content:center;font-size:16px;line-height:1;" onclick={`removePhoto(${slot.n})`} title="Remove Photo">&times;</button>
