---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Icon from '../../components/Icon.astro';
---

<DashboardLayout title="View Valuation" subtitle="Detailed vehicle valuation record" role="admin" activePage="search">
  <div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h1 id="pageTitle">Valuation Details</h1>
      <p>Complete read-only view of the vehicle valuation</p>
    </div>
    <div style="display: flex; gap: 8px;">
      <button class="btn btn-secondary" onclick="window.history.back()">← Back</button>
      <button class="btn btn-primary" id="printBtn" style="display:none;" onclick="printReport()"><Icon name="printer" size="16"/> Print Report</button>
    </div>
  </div>

  <div id="loadingIndicator" style="padding: 40px; text-align: center; color: var(--neutral-500);">
    Loading valuation details...
  </div>

  <div id="detailsContent" style="display: none; display: flex; flex-direction: column; gap: 16px;">
    
    <!-- Vehicle Summary Card -->
    <div class="card" style="border-top: 4px solid var(--primary-500);">
      <div class="card-body" style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center; justify-content: space-between; padding: 16px;">
        <div style="display: flex; gap: 12px; align-items: center;">
          <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--primary-50); color: var(--primary-600); display: flex; align-items: center; justify-content: center;">
            <Icon name="clipboard" size="24"/>
          </div>
          <div>
            <h2 id="summaryReg" style="margin: 0; font-size: 1.25rem; color: var(--neutral-800);"></h2>
            <div id="summaryMakeModel" style="color: var(--neutral-500); font-size: 0.85rem; margin-top: 2px;"></div>
          </div>
        </div>
        <div style="display: flex; gap: 24px; flex-wrap: wrap;">
          <div>
            <div style="font-size: 0.75rem; color: var(--neutral-400); text-transform: uppercase; font-weight: 600;">Market Value</div>
            <div id="summaryValue" style="font-size: 1.15rem; font-weight: 700; color: var(--success-600);"></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; color: var(--neutral-400); text-transform: uppercase; font-weight: 600;">Status</div>
            <div id="summaryStatus" style="margin-top: 2px;"></div>
          </div>
          <div>
            <div style="font-size: 0.75rem; color: var(--neutral-400); text-transform: uppercase; font-weight: 600;">YOM</div>
            <div id="summaryYom" style="font-size: 1rem; font-weight: 600; color: var(--neutral-700);"></div>
          </div>
        </div>
      </div>
    </div>

    <div style="display: flex; flex-wrap: wrap; gap: 16px;">
      
      <!-- General Info -->
      <div class="card" style="flex: 1 1 400px;">
        <div class="card-header" style="padding: 12px 16px;">
          <div class="card-title"><div class="icon" style="background:var(--info-100);color:var(--info-600); width: 24px; height: 24px;"><Icon name="dashboard" size="14" /></div> General Information</div>
        </div>
        <div class="card-body" style="padding: 16px;">
          <div class="detail-grid">
            <div class="detail-item"><span class="label">Chassis No</span><span class="value" id="val_chassis_no"></span></div>
            <div class="detail-item"><span class="label">Engine No</span><span class="value" id="val_engine_no"></span></div>
            <div class="detail-item"><span class="label">Engine Capacity</span><span class="value" id="val_engine_capacity"></span></div>
            <div class="detail-item"><span class="label">Fuel Type</span><span class="value" id="val_fuel_type"></span></div>
            <div class="detail-item"><span class="label">Body Color</span><span class="value" id="val_body_color"></span></div>
            <div class="detail-item"><span class="label">Meter Reading</span><span class="value" id="val_meter_reading"></span></div>
            <div class="detail-item"><span class="label">Seating Cap</span><span class="value" id="val_seating_cap"></span></div>
            <div class="detail-item"><span class="label">Current Owner</span><span class="value" id="val_current_owner"></span></div>
            <div class="detail-item"><span class="label">Country of Origin</span><span class="value" id="val_country_origin"></span></div>
            <div class="detail-item"><span class="label">Country Used</span><span class="value" id="val_country_used"></span></div>
          </div>
        </div>
      </div>

      <!-- Financials -->
      <div class="card" style="flex: 1 1 400px;">
        <div class="card-header" style="padding: 12px 16px;">
          <div class="card-title"><div class="icon" style="background:var(--success-100);color:var(--success-600); width: 24px; height: 24px;"><Icon name="finance" size="14" /></div> Financials & Opinion</div>
        </div>
        <div class="card-body" style="padding: 16px;">
          <div class="detail-grid">
            <div class="detail-item"><span class="label">Market Value</span><span class="value highlight" id="val_market_value"></span></div>
            <div class="detail-item"><span class="label">Forced Value</span><span class="value" id="val_forced_value"></span></div>
            <div class="detail-item"><span class="label">Valuation Amount</span><span class="value" id="val_val_amount"></span></div>
            <div class="detail-item"><span class="label">VAT</span><span class="value" id="val_vat"></span></div>
            <div class="detail-item"><span class="label">Finance Company</span><span class="value" id="val_finance_company"></span></div>
            <div class="detail-item"><span class="label">Finance Branch</span><span class="value" id="val_finance_branch"></span></div>
            <div class="detail-item"><span class="label">Opinion To</span><span class="value" id="val_opinion_to"></span></div>
            <div class="detail-item"><span class="label">Yard</span><span class="value" id="val_yard"></span></div>
            <div class="detail-item"><span class="label">Inspection Date</span><span class="value" id="val_inspection_date"></span></div>
            <div class="detail-item"><span class="label">Location</span><span class="value" id="val_inspect_location"></span></div>
          </div>
        </div>
      </div>
    </div> <!-- End Top Row Cards -->

    <!-- Technical Condition -->
    <div class="card">
      <div class="card-header" style="padding: 12px 16px;">
        <div class="card-title"><div class="icon" style="background:var(--warning-100);color:var(--warning-600); width: 24px; height: 24px;"><Icon name="inspection" size="14" /></div> Technical & Condition</div>
      </div>
      <div class="card-body" style="padding: 16px;">
        <div class="detail-grid grid-3">
          <div class="detail-item"><span class="label">Transmission</span><span class="value" id="val_transmission"></span></div>
          <div class="detail-item"><span class="label">Gearbox Condition</span><span class="value" id="val_gearbox_con"></span></div>
          <div class="detail-item"><span class="label">Engine Condition</span><span class="value" id="val_engine_con"></span></div>
          <div class="detail-item"><span class="label">Engine Status</span><span class="value" id="val_engine_status"></span></div>
          <div class="detail-item"><span class="label">Body Condition</span><span class="value" id="val_body_con"></span></div>
          <div class="detail-item"><span class="label">Chassis Condition</span><span class="value" id="val_chassis_con"></span></div>
          <div class="detail-item"><span class="label">Vehicle Condition</span><span class="value" id="val_vehicle_con"></span></div>
          <div class="detail-item"><span class="label">Vehicle Type</span><span class="value" id="val_vehicle_type"></span></div>
          <div class="detail-item"><span class="label">Body Type</span><span class="value" id="val_body_type"></span></div>
          <div class="detail-item"><span class="label">AC Condition</span><span class="value" id="val_ac_con"></span></div>
          <div class="detail-item"><span class="label">Steering</span><span class="value" id="val_steering"></span></div>
          <div class="detail-item"><span class="label">Fuel System</span><span class="value" id="val_fuel_system"></span></div>
        </div>
        
        <hr style="border: 0; border-top: 1px solid var(--neutral-100); margin: 16px 0;"/>
        
        <h4 style="margin-top: 0; margin-bottom: 12px; font-size: 0.9rem; color: var(--neutral-600);">Additional Details & Remarks</h4>
        <div class="detail-grid">
          <div class="detail-item full-width"><span class="label">Special Features</span><span class="value" id="val_special_feature"></span></div>
          <div class="detail-item full-width"><span class="label">Extra Options</span><span class="value" id="val_extra_options"></span></div>
          <div class="detail-item full-width"><span class="label">Repairs Needed</span><span class="value" id="val_need_repair"></span></div>
          <div class="detail-item full-width"><span class="label">Accident History</span><span class="value" id="val_accident"></span></div>
          <div class="detail-item full-width"><span class="label">Comments</span><span class="value" id="val_comments_1"></span></div>
        </div>
      </div>
    </div>

    <!-- Photos -->
    <div class="card">
      <div class="card-header" style="padding: 12px 16px;">
        <div class="card-title"><div class="icon" style="background:#f0fdf4;color:#16a34a; width: 24px; height: 24px;"><Icon name="profile" size="14" /></div> Photos</div>
      </div>
      <div class="card-body" style="padding: 16px;">
        <div id="photosGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px;">
          <div class="no-data" id="noPhotosMsg">No photos available.</div>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<style is:global>
  .detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
  }
  .detail-grid.grid-3 {
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }
  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: var(--neutral-50);
    padding: 8px 12px;
    border-radius: 6px;
    border: 1px solid var(--neutral-100);
  }
  .detail-item.full-width {
    grid-column: 1 / -1;
  }
  .detail-item .label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--neutral-400);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .detail-item .value {
    font-size: 0.85rem;
    color: var(--neutral-800);
    font-weight: 500;
    word-break: break-word;
  }
  .detail-item .value.highlight {
    color: var(--primary-600);
    font-weight: 700;
  }
  .photo-thumbnail {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--neutral-200);
    cursor: pointer;
    transition: transform 0.2s;
  }
  .photo-thumbnail:hover {
    transform: scale(1.02);
  }
  .badge {
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }
</style>

<script>
const API = 'http://localhost:8080';
const token = localStorage.getItem('aw_token') || '';
let currentValuationId = null;

async function loadData() {
  const params = new URLSearchParams(window.location.search);
  const id = params.get('id');
  if (!id) {
    document.getElementById('loadingIndicator').textContent = 'Error: No valuation ID provided.';
    return;
  }
  currentValuationId = id;

  try {
    const res = await fetch(`${API}/api/valuations/${id}`, {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await res.json();
    if (!data.success || !data.data) {
      document.getElementById('loadingIndicator').textContent = 'Valuation not found.';
      return;
    }

    renderData(data.data);
    
    document.getElementById('loadingIndicator').style.display = 'none';
    document.getElementById('detailsContent').style.display = 'flex';
    document.getElementById('printBtn').style.display = 'inline-flex';
    
  } catch(e) {
    console.error(e);
    document.getElementById('loadingIndicator').textContent = 'Failed to load valuation details.';
  }
}

function renderData(v) {
  document.getElementById('pageTitle').textContent = `Valuation #${v.id}`;
  document.getElementById('summaryReg').textContent = v.reg_no || 'N/A';
  document.getElementById('summaryMakeModel').textContent = `${v.make || ''} ${v.model || ''}`;
  document.getElementById('summaryValue').textContent = v.market_value ? `Rs. ${Number(v.market_value).toLocaleString()}` : 'N/A';
  document.getElementById('summaryYom').textContent = v.yom || 'N/A';
  
  const st = v.status || 'Pending';
  const cls = st === 'Approved' ? 'badge-success' : st === 'Rejected' ? 'badge-danger' : 'badge-warning';
  document.getElementById('summaryStatus').innerHTML = `<span class="badge ${cls}">${st}</span>`;

  // Bind values
  const bind = (id, val, format = null) => {
    const el = document.getElementById(id);
    if (!el) return;
    if (!val && val !== 0) {
      el.innerHTML = '<span style="color:var(--neutral-300)">—</span>';
      return;
    }
    if (format === 'money') {
      el.textContent = `Rs. ${Number(val).toLocaleString()}`;
    } else if (format === 'date') {
      el.textContent = new Date(val).toLocaleDateString();
    } else {
      el.textContent = val;
    }
  };

  bind('val_chassis_no', v.chassis_no);
  bind('val_engine_no', v.engine_no);
  bind('val_engine_capacity', v.engine_capacity ? `${v.engine_capacity} cc` : null);
  bind('val_fuel_type', v.fuel_type);
  bind('val_body_color', v.body_color);
  bind('val_meter_reading', v.meter_reading ? `${v.meter_reading} ${v.meter_unit || ''}` : null);
  bind('val_seating_cap', v.seating_cap);
  bind('val_current_owner', v.current_owner);
  bind('val_country_origin', v.country_origin);
  bind('val_country_used', v.country_used);

  bind('val_market_value', v.market_value, 'money');
  bind('val_forced_value', v.forced_value, 'money');
  bind('val_val_amount', v.val_amount, 'money');
  bind('val_vat', v.vat ? 'Yes' : 'No');
  bind('val_finance_company', v.finance_company);
  bind('val_finance_branch', v.finance_branch);
  bind('val_opinion_to', v.opinion_to);
  bind('val_yard', v.yard);
  bind('val_inspection_date', v.inspection_date, 'date');
  bind('val_inspect_location', v.inspect_location);

  bind('val_transmission', v.transmission);
  bind('val_gearbox_con', v.gearbox_con);
  bind('val_engine_con', v.engine_con);
  bind('val_engine_status', v.engine_status);
  bind('val_body_con', v.body_con);
  bind('val_chassis_con', v.chassis_con);
  bind('val_vehicle_con', v.vehicle_con);
  bind('val_vehicle_type', v.vehicle_type);
  bind('val_body_type', v.body_type);
  bind('val_ac_con', v.ac_con);
  bind('val_steering', v.steering);
  bind('val_fuel_system', v.fuel_system);

  bind('val_special_feature', v.special_feature);
  bind('val_extra_options', v.extra_options);
  bind('val_need_repair', v.need_within_year);
  bind('val_accident', v.accident);
  bind('val_comments_1', v.comments_1);

  // Photos
  if (v.image_paths && Array.isArray(v.image_paths) && v.image_paths.some(p => p)) {
    const grid = document.getElementById('photosGrid');
    grid.innerHTML = '';
    const labels = ['Chassis Number', 'Engine Number', 'Speedometer', 'Front View', 'Rear View'];
    v.image_paths.forEach((p, i) => {
      if (p) {
        grid.innerHTML += `
          <div style="display:flex; flex-direction:column; gap:8px;">
            <a href="${API}${p}" target="_blank" title="View Full Image">
              <img src="${API}${p}" class="photo-thumbnail" alt="${labels[i] || 'Photo'}"/>
            </a>
            <div style="font-size:0.8rem; font-weight:600; text-align:center; color:var(--neutral-600);">${labels[i] || 'Photo ' + (i+1)}</div>
          </div>
        `;
      }
    });
  }
}

window.printReport = function() {
  if (currentValuationId) {
    window.open(`/reports/${currentValuationId}?token=${encodeURIComponent(token)}`, '_blank');
  }
};

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', loadData);
} else {
  loadData();
}
</script>
