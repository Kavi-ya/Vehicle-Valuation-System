{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/add-valuation/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/create-user/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/form-options/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/pending/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/profile/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/reports/branch/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/reports/finance/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/reports/inspection/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/search/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/users/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/valuations/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/view-valuation/?$",
			"dest": "_render"
		},
		{
			"src": "^/reports/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/user/add-valuation/?$",
			"dest": "_render"
		},
		{
			"src": "^/user/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/user/form-options/?$",
			"dest": "_render"
		},
		{
			"src": "^/user/profile/?$",
			"dest": "_render"
		},
		{
			"src": "^/user/search/?$",
			"dest": "_render"
		},
		{
			"src": "^/user/valuations/?$",
			"dest": "_render"
		},
		{
			"src": "^/user/view-valuation/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}