---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Icon from '../../components/Icon.astro';
---
<DashboardLayout title="My Dashboard" subtitle="Personal Valuation Overview" role="user" activePage="dashboard">

  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <h1>My Dashboard</h1>
      <p>Your personal vehicle valuation overview</p>
    </div>
    <a href="/user/add-valuation" class="btn btn-green"><Icon name="plus" /> Add Valuation</a>
  </div>

  <!-- Quick Actions -->
  <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;">
    <a href="/user/add-valuation" class="btn btn-primary btn-sm"><Icon name="plus" size="14" /> New Valuation</a>
    <a href="/user/search"        class="btn btn-secondary btn-sm"><Icon name="search" size="14" /> Search Vehicle</a>
    <a href="/user/valuations"    class="btn btn-secondary btn-sm"><Icon name="clipboard" size="14" /> My Valuations</a>
  </div>

  <!-- Stats -->
  <div class="stats-grid" style="margin-bottom:24px;">
    <div class="stat-card blue">
      <div class="stat-icon blue"><Icon name="calendar" /></div>
      <div><div class="stat-value" id="uToday">—</div><div class="stat-label">Today's Valuations</div></div>
    </div>
    <div class="stat-card purple">
      <div class="stat-icon purple"><Icon name="calendar" /></div>
      <div><div class="stat-value" id="uMonthly">—</div><div class="stat-label">Monthly Valuations</div></div>
    </div>
    <div class="stat-card green">
      <div class="stat-icon green"><Icon name="checkcircle" /></div>
      <div><div class="stat-value" id="uApproved">—</div><div class="stat-label">Approved</div></div>
    </div>
    <div class="stat-card amber">
      <div class="stat-icon amber"><Icon name="clock" /></div>
      <div><div class="stat-value" id="uPending">—</div><div class="stat-label">Pending</div></div>
    </div>
    <div class="stat-card red">
      <div class="stat-icon red"><Icon name="xcircle" /></div>
      <div><div class="stat-value" id="uRejected">—</div><div class="stat-label">Rejected</div></div>
    </div>
  </div>

  <!-- Detailed Summaries -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:18px;margin-bottom:24px;">
    <!-- User Summary -->
    <div class="card" style="border:1px solid var(--blue-200);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);">
      <div class="summary-header">
        <span style="flex-shrink:0;display:flex;align-items:center;"><Icon name="user" size="16" /></span>
        <span>User Summary</span>
      </div>
      <div style="padding:0;">
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><Icon name="monitor" size="15" /> Today Valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="usToday">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><Icon name="calendar" size="15" /> Monthly Valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="usMonthly">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><Icon name="plus" size="15" /> Total valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="usTotal">—</span>
        </div>
      </div>
    </div>

    <!-- Branch Summary -->
    <div class="card" style="border:1px solid var(--blue-200);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);">
      <div class="summary-header">
        <span style="flex-shrink:0;display:flex;align-items:center;"><Icon name="building" size="16" /></span>
        <span>Branch Summary</span>
      </div>
      <div style="padding:0;">
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><Icon name="monitor" size="15" /> Today Valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="bsToday">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><Icon name="calendar" size="15" /> Monthly Valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="bsMonthly">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><Icon name="plus" size="15" /> Total valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="bsTotal">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><Icon name="users" size="15" /> Branch Users</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="bsUsers">—</span>
        </div>
      </div>
    </div>
  </div>

  <!-- My Recent Valuations -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">
        <div class="icon" style="background:var(--brand-50);color:var(--brand-700);"><Icon name="clipboard" /></div>
        My Recent Valuations
      </div>
      <a href="/user/valuations" class="btn btn-ghost btn-sm">View All →</a>
    </div>
    <div class="table-wrapper" style="border:none;border-radius:0;">
      <table>
        <thead>
          <tr><th>ID</th><th>Register No.</th><th>Make</th><th>Model</th><th>Value</th><th>Status</th><th>Date</th></tr>
        </thead>
        <tbody id="myValTable">
          <tr><td colspan="7" style="text-align:center;padding:28px;color:#9ca3af;">Loading…</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>

<script>
const API   = 'http://localhost:8080';
const token = localStorage.getItem('aw_token') || '';

async function loadStats() {
  try {
    const res  = await fetch(`${API}/api/stats`, { headers: { 'Authorization': 'Bearer ' + token } });
    const data = await res.json();
    if (data.success && data.data) {
      const setTxt = (id: string, val: any) => { const el = document.getElementById(id); if (el) el.textContent = String(val); };
      setTxt('uToday', data.data.today_valuations || 0);
      setTxt('uMonthly', data.data.monthly_valuations || 0);
      setTxt('uApproved', data.data.approved_valuations || 0);
      setTxt('uPending', data.data.pending_valuations || 0);
      setTxt('uRejected', data.data.rejected_valuations || 0);

      const d = data.data;
      setTxt('usToday', (d.user_today || 0).toLocaleString());
      setTxt('usMonthly', (d.user_monthly || 0).toLocaleString());
      setTxt('usTotal', (d.user_total || 0).toLocaleString());

      setTxt('bsToday', (d.branch_today || 0).toLocaleString());
      setTxt('bsMonthly', (d.branch_monthly || 0).toLocaleString());
      setTxt('bsTotal', (d.branch_total || 0).toLocaleString());
      setTxt('bsUsers', (d.branch_users || 0).toLocaleString());
    }
  } catch(e) {}
}

async function loadRecent() {
  try {
    const res   = await fetch(`${API}/api/valuations?per_page=5`, { headers: { 'Authorization': 'Bearer ' + token } });
    const data  = await res.json();
    const tbody = document.getElementById('myValTable');
    if (!tbody) return;
    if (!data.success || !data.data?.items?.length) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:28px;color:#9ca3af;">No valuations found</td></tr>';
      return;
    }
    tbody.innerHTML = data.data.items.map((v: any) => `
      <tr>
        <td class="td-mono">${v.id}</td>
        <td class="td-mono" style="font-weight:600;">${v.reg_no || '—'}</td>
        <td>${v.make || '—'}</td>
        <td style="color:var(--ink-500);">${v.model || '—'}</td>
        <td class="td-mono">Rs. ${(v.market_value||0).toLocaleString()}</td>
        <td><span class="badge ${v.status==='Approved'?'badge-success':v.status==='Rejected'?'badge-danger':'badge-warning'}">${v.status||'Pending'}</span></td>
        <td class="td-mono" style="font-size:.77rem;">${new Date(v.created_at).toLocaleDateString()}</td>
      </tr>
    `).join('');
  } catch(e) {
    const tbody = document.getElementById('myValTable');
    if (tbody) tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:28px;color:#9ca3af;">Could not load data</td></tr>';
  }
}

loadStats();
loadRecent();
</script>
