---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import Icon from '../../components/Icon.astro';

const optionTypes = [
  'Air type',
  'Body Color',
  'Body Conditions',
  'Body type',
  'Brake Conditions',
  'Brake Type',
  'Clutch Conditions',
  'Clutch type',
  'Countries',
  'Differential Condition',
  'Differential Type',
  'Electrical Condition',
  'Finance Branch',
  'Finance Company',
  'Fuel System',
  'Fuel Types',
  'Gearbox Condition',
  'Inspectors',
  'Interior Types',
  'Maintain Conditions',
  'Make Details',
  'Opinion provider',
  'Option Condition',
  'Seat Data',
  'Starter Types',
  'Steering Types',
  'Suspension Conditions',
  'Suspension Type',
  'Test Types',
  'Transmission Types',
  'Types of Vehicle',
  'Tyre Front Type',
  'Tyre Material Type',
  'Tyre Rear Type',
  'Tyre Wheel Type',
  'VAT Status',
  'Vehicle Condition',
  'Wiper Type',
  'Yard Details'
];
---
<DashboardLayout title="Form Options" subtitle="Manage dropdown options for valuation forms" role="admin" activePage="form-options">

  <div class="page-header">
    <h1>Form Options</h1>
    <p>Add and manage options for all form dropdown fields</p>
  </div>

  <style>
  .cat-item {
    break-inside: avoid;
    cursor: pointer;
    padding: 2px 4px;
    border-radius: 4px;
    transition: background-color 0.2s, color 0.2s;
  }
  .cat-item:hover {
    background-color: var(--primary-50);
    color: var(--primary-700);
  }
  .cat-item.active {
    background-color: var(--primary-100);
    color: var(--primary-800);
    font-weight: 600;
  }
  </style>

  <!-- Form Options Categories List Banner (Matching Image) -->
  <div style="background:#fff;border:1px solid var(--neutral-200);margin-bottom:24px;box-shadow:var(--shadow-sm);">
    <div style="padding:16px 24px;">
      <ul style="column-count:5;column-gap:24px;list-style-type:disc;margin:0;padding-left:16px;font-size:0.75rem;color:var(--neutral-700);line-height:1.8;">
        {optionTypes.map(t => <li class="cat-item" onclick={`selectCategory('${t}', this)`}>{t}</li>)}
      </ul>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:320px 1fr;gap:20px;align-items:start;">

    <!-- Left: Add Option -->
    <div class="card" style="position:sticky;top:80px;">
      <div class="card-header">
        <div class="card-title" id="formCardTitle">
          <div class="icon" style="background:var(--primary-100);color:var(--primary-600);"><Icon name="plus" /></div>
          <span>Add New Option</span>
        </div>
      </div>
      <div class="card-body">
        <form onsubmit="addOption(event)" style="display:flex;flex-direction:column;gap:14px;">
          <input type="hidden" id="opt_id" value="" />
          <div class="form-group">
            <label>Option Type <span class="required">*</span></label>
            <select class="form-control" id="sel_type" required>
              <option value="">— Select option type —</option>
              {optionTypes.map(t => <option>{t}</option>)}
            </select>
          </div>
          <div class="form-group">
            <label>Option Value <span class="required">*</span></label>
            <input type="text" class="form-control" id="opt_value" placeholder="Enter option value" required />
          </div>
          <div class="form-group">
            <label>Option Label</label>
            <input type="text" class="form-control" id="opt_label" placeholder="Enter display name/label" />
          </div>
          <div class="form-group">
            <label>Sort Order</label>
            <input type="number" class="form-control" id="opt_sort" placeholder="e.g. 10" min="0" />
          </div>
          <div id="addMsg" style="display:none;"></div>
          <div style="display:flex;gap:10px;">
            <button type="submit" class="btn btn-primary" id="saveOptBtn" style="flex:1;"><Icon name="check" size="16"/> Add Option</button>
            <button type="button" class="btn btn-ghost" id="cancelEditBtn" style="display:none;flex:1;" onclick="cancelEdit()">Cancel Edit</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Right: Options List -->
    <div class="card" id="optionsCard" style="display:none;">
      <div class="card-header">
        <div class="card-title" id="optionsCardTitle">
          <div class="icon" style="background:var(--neutral-100);color:var(--neutral-600);"><Icon name="cog" /></div>
          <span>Select a Category</span>
        </div>
        <div class="search-bar">
          <span class="search-icon"><Icon name="search" size="14" /></span>
          <input type="text" class="form-control" id="optSearch" placeholder="Search options..." style="width:200px;" oninput="searchOptions()" />
        </div>
      </div>

      <div class="table-wrapper" style="border:none;border-radius:0;">
        <table id="optTable">
          <thead>
            <tr>
              <th>Option Value</th>
              <th>Option Label</th>
              <th>Sort</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="optTbody">
            <!-- Populated by JS -->
          </tbody>
        </table>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
const API = 'http://localhost:8080';
let allOptions = [];
let currentCategory = '';

async function loadOptions() {
  try {
    const token = localStorage.getItem('aw_token');
    if (!token) { window.location.href='/'; return; }
    const res = await fetch(`${API}/api/options`, { headers: { 'Authorization': 'Bearer ' + token }});
    if (!res.ok) throw new Error('Failed to load options');
    const json = await res.json();
    allOptions = json.data || [];
    if(currentCategory) renderOptions();
  } catch(err) {
    console.error(err);
  }
}

window.selectCategory = function(cat, el) {
  currentCategory = cat;
  
  document.querySelectorAll('.cat-item').forEach(li => li.classList.remove('active'));
  if (el) el.classList.add('active');
  
  document.getElementById('optionsCard').style.display = 'block';
  document.getElementById('optionsCardTitle').innerHTML = `
    <span>Options for: ${cat}</span>
  `;

  const selType = document.getElementById('sel_type');
  if (selType) selType.value = cat;

  renderOptions();
};

const mapSelectsToOptions = {
  'sel_openion_provider': 'Opinion provider',
  'sel_finance': 'Finance Company',
  'sel_finance_branch': 'Finance Branch',
  'sel_make': 'Make Details',
  'sel_country_origin': 'Countries',
  'sel_country_used': 'Countries',
  'sel_fuel_type': 'Fuel Types',
  'sel_color': 'Body Color',
  'sel_seat': 'Seat Data',
  'sel_fuel_sys': 'Fuel System',
  'sel_yard': 'Yard Details',
  'sel_branch': 'Finance Branch',
  'sel_vat': 'VAT Status',
  'sel_transmission': 'Transmission Types',
  'sel_gearbox_con': 'Gearbox Condition',
  'sel_wheel_type': 'Tyre Wheel Type',
  'sel_tyre_front_type': 'Tyre Front Type',
  'sel_tyrefr_meterial': 'Tyre Material Type',
  'sel_tyre_rear_type': 'Tyre Rear Type',
  'sel_tyrere_meterial': 'Tyre Material Type',
  'sel_starter': 'Starter Types',
  'sel_starter_con': 'Electrical Condition',
  'sel_clutch': 'Clutch type',
  'sel_clutch_con': 'Clutch Conditions',
  'sel_wiper_type': 'Wiper Type',
  'sel_wiper_con': 'Option Condition',
  'sel_shaft_type': 'Suspension Type',
  'sel_shaft_con': 'Suspension Conditions',
  'sel_differential': 'Differential Type',
  'sel_differential_con': 'Differential Condition',
  'sel_horn_con': 'Option Condition',
  'sel_light_con': 'Option Condition',
  'sel_meter_con': 'Option Condition',
  'sel_alternator_con': 'Option Condition',
  'sel_foot_brake': 'Brake Type',
  'sel_ftbrake_con': 'Brake Conditions',
  'sel_pkbrake_con': 'Brake Conditions',
  'sel_steering': 'Steering Types',
  'sel_steering_con': 'Option Condition',
  'sel_suspen_fr_type': 'Suspension Type',
  'sel_suspen_fr_con': 'Suspension Conditions',
  'sel_suspen_re_type': 'Suspension Type',
  'sel_suspen_re_con': 'Suspension Conditions',
  'sel_engine_con': 'Maintain Conditions',
  'sel_engine_status': 'Vehicle Condition',
  'sel_body_con': 'Body Conditions',
  'sel_chassis_con': 'Maintain Conditions',
  'sel_pwshutter_con': 'Option Condition',
  'sel_pwmirror_con': 'Option Condition',
  'sel_air_type': 'Air type',
  'sel_ac_con': 'Option Condition',
  'sel_body_maint': 'Maintain Conditions',
  'sel_vehicle_con': 'Vehicle Condition',
  'sel_intertrim': 'Interior Types',
  'sel_intertrim_con': 'Option Condition',
  'sel_vehicle_type': 'Types of Vehicle',
  'sel_body_type': 'Body type',
  'sel_test_type': 'Test Types',
  'sel_complience_envir': 'Option Condition',
  'sel_inspection': 'Inspectors',
};

function renderOptions() {
  if (!currentCategory) return;
  const tbody = document.getElementById('optTbody');
  tbody.innerHTML = '';
  
  const catLower = currentCategory.toLowerCase();
  
  const validDbKeys = Object.keys(mapSelectsToOptions)
    .filter(k => mapSelectsToOptions[k].toLowerCase() === catLower)
    .map(k => k.toLowerCase());
  validDbKeys.push(catLower);
  
  const filtered = allOptions.filter(o => 
    o.option_type && validDbKeys.includes(o.option_type.toLowerCase())
  ).sort((a,b) => (a.sort_order||0) - (b.sort_order||0));
  
  if (filtered.length === 0) {
    tbody.innerHTML = `<tr><td colspan="3" style="text-align:center;color:var(--neutral-400);padding:20px;">No options found for this category.</td></tr>`;
    return;
  }

  filtered.forEach(o => {
    const row = document.createElement('tr');
    row.dataset.id = o.id;
    row.dataset.val = o.value.toLowerCase();
    row.innerHTML = `
      <td style="font-weight:500;">${o.value}</td>
      <td style="color:var(--primary-700);">${o.label || '—'}</td>
      <td class="td-mono" style="color:var(--neutral-400);">${o.sort_order}</td>
      <td>
        <div style="display:flex;gap:4px;">
          <button class="btn btn-ghost btn-sm" style="color:var(--primary-600);padding:4px;" title="Edit" onclick="editOpt(${o.id})">${window.ICONS.edit || 'Edit'}</button>
          <button class="btn btn-ghost btn-sm" style="color:var(--danger-500);padding:4px;" title="Delete" onclick="deleteOpt(${o.id}, this)">${window.ICONS.trash}</button>
        </div>
      </td>`;
    tbody.appendChild(row);
  });
}

window.addOption = async function(e) {
  e.preventDefault();
  const token = localStorage.getItem('aw_token');
  const type  = document.getElementById('sel_type').value;
  const val   = document.getElementById('opt_value').value;
  const label = document.getElementById('opt_label').value;
  const sort  = parseInt(document.getElementById('opt_sort').value || '0', 10);
  const optId = document.getElementById('opt_id').value;
  const msg   = document.getElementById('addMsg');

  try {
    const isEdit = !!optId;
    const method = isEdit ? 'PUT' : 'POST';
    const url = isEdit ? `${API}/api/options/${optId}` : `${API}/api/options`;

    const res = await fetch(url, {
      method: method,
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + token
      },
      body: JSON.stringify({ option_type: type, value: val, label: label, sort_order: sort })
    });
    
    if (!res.ok) throw new Error(isEdit ? 'Failed to update option' : 'Failed to add option');
    const json = await res.json();
    
    if (isEdit) {
      allOptions = allOptions.map(o => o.id === parseInt(optId) ? json.data : o);
      msg.innerHTML = '<div class="alert alert-success">' + window.ICONS.checkcircle + ' Option updated successfully!</div>';
      cancelEdit();
    } else {
      if (json.data) allOptions.push(json.data);
      msg.innerHTML = '<div class="alert alert-success">' + window.ICONS.checkcircle + ' Option added successfully!</div>';
      e.target.reset();
      document.getElementById('sel_type').value = currentCategory;
    }
    
    msg.style.display = 'block';
    
    if (type === currentCategory) {
      renderOptions();
    }
  } catch(err) {
    msg.innerHTML = '<div class="alert alert-danger">' + window.ICONS.xcircle + ' Error saving option.</div>';
    msg.style.display = 'block';
  }
  setTimeout(() => msg.style.display = 'none', 3000);
};

window.editOpt = function(id) {
  const opt = allOptions.find(o => o.id === id);
  if (!opt) return;
  
  document.getElementById('opt_id').value = opt.id;
  document.getElementById('sel_type').value = opt.option_type || '';
  document.getElementById('opt_value').value = opt.value || '';
  document.getElementById('opt_label').value = opt.label || '';
  document.getElementById('opt_sort').value = opt.sort_order || 0;
  
  document.getElementById('formCardTitle').innerHTML = `
    <div class="icon" style="background:var(--primary-100);color:var(--primary-600);">${window.ICONS.edit || 'Edit'}</div>
    <span>Edit Option</span>
  `;
  document.getElementById('saveOptBtn').innerHTML = `${window.ICONS.check || ''} Save Option`;
  document.getElementById('cancelEditBtn').style.display = 'inline-block';
};

window.cancelEdit = function() {
  document.getElementById('opt_id').value = '';
  document.getElementById('opt_value').value = '';
  document.getElementById('opt_label').value = '';
  document.getElementById('opt_sort').value = '';
  document.getElementById('sel_type').value = currentCategory;
  
  document.getElementById('formCardTitle').innerHTML = `
    <div class="icon" style="background:var(--primary-100);color:var(--primary-600);">${window.ICONS.plus || '+'}</div>
    <span>Add New Option</span>
  `;
  document.getElementById('saveOptBtn').innerHTML = `${window.ICONS.check || ''} Add Option`;
  document.getElementById('cancelEditBtn').style.display = 'none';
};

window.deleteOpt = async function(id, btn) {
  if (!confirm('Delete this option?')) return;
  const token = localStorage.getItem('aw_token');
  
  try {
    const res = await fetch(`${API}/api/options/` + id, {
      method: 'DELETE',
      headers: { 'Authorization': 'Bearer ' + token }
    });
    if (!res.ok) throw new Error('Failed to delete');
    
    allOptions = allOptions.filter(o => o.id !== id);
    btn.closest('tr').remove();
  } catch(err) {
    alert('Error deleting option');
  }
};

window.searchOptions = function() {
  const q = document.getElementById('optSearch').value.toLowerCase();
  document.querySelectorAll('#optTbody tr').forEach(r => {
    if (!r.dataset.val) return;
    r.style.display = r.dataset.val.includes(q) ? '' : 'none';
  });
};

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', loadOptions);
} else {
  loadOptions();
}
</script>
