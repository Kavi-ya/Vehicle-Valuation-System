---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import Icon from '../../../components/Icon.astro';
---
<DashboardLayout title="Finance Summary" subtitle="Revenue and fee collection overview" role="admin" activePage="finance">

  <div class="page-header">
    <h1>Finance Summary</h1>
    <p>Revenue overview across branches and periods</p>
  </div>

  <!-- Filter -->
  <div class="card" style="margin-bottom:20px;">
    <div class="card-body">
      <div class="form-grid" style="grid-template-columns:repeat(4,1fr);">
        <div class="form-group">
          <label>Branch</label>
          <select class="form-control" id="f_branch" onchange="loadReport()">
            <option value="">All Branches</option>
            <option>Monaragala</option><option>BADULLA</option><option>BANDARAWELA</option><option>KENDY</option>
          </select>
        </div>
        <div class="form-group">
          <label>Month</label>
          <select class="form-control" id="f_month" onchange="loadReport()">
            <option value="">All Months</option>
            {['January','February','March','April','May','June','July','August','September','October','November','December'].map((m,i) => <option value={i+1}>{m}</option>)}
          </select>
        </div>
        <div class="form-group">
          <label>Year</label>
          <select class="form-control" id="f_year" onchange="loadReport()">
            {[2025,2024,2023,2022,2021].map(y => <option>{y}</option>)}
          </select>
        </div>
        <div class="form-group">
          <label>User</label>
          <select class="form-control" id="f_user" onchange="loadReport()">
            <option value="">All Users</option>
            <option>pac1</option><option>Prasanna</option><option>SILVESTER</option><option>JAYAMINI</option>
          </select>
        </div>
      </div>
      <div style="display:flex;gap:8px;margin-top:12px;">
        <button class="btn btn-primary" onclick="loadReport()"><Icon name="trending" size="14"/> Generate Report</button>
        <button class="btn btn-secondary" onclick="exportReport()"><Icon name="download" size="14"/> Export</button>
      </div>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
    <div class="stat-card blue">
      <div class="stat-icon blue"><Icon name="dollar" /></div>
      <div><div class="stat-value" id="totalRevenue">Rs. 1.24M</div><div class="stat-label">Total Revenue</div></div>
    </div>
    <div class="stat-card green">
      <div class="stat-icon green"><Icon name="clipboard" /></div>
      <div><div class="stat-value" id="totalVal">1,373</div><div class="stat-label">Valuations Billed</div></div>
    </div>
    <div class="stat-card amber">
      <div class="stat-icon amber"><Icon name="car" /></div>
      <div><div class="stat-value" id="avgFee">Rs. 903</div><div class="stat-label">Avg. Fee / Valuation</div></div>
    </div>
    <div class="stat-card cyan">
      <div class="stat-icon cyan"><Icon name="car" /></div>
      <div><div class="stat-value" id="totalTravel">Rs. 87k</div><div class="stat-label">Total Travel Fees</div></div>
    </div>
  </div>

  <!-- Table -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">
        <div class="icon" style="background:var(--success-100);color:#16a34a;"><Icon name="dollar" /></div>
        Detailed Finance Records
      </div>
    </div>
    <div class="table-wrapper" style="border:none;border-radius:0;">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Register No.</th>
            <th>Branch</th>
            <th>Date</th>
            <th>Val. Amount</th>
            <th>Travel Amount</th>
            <th>Re-report Amt</th>
            <th>Total</th>
            <th>VAT</th>
          </tr>
        </thead>
        <tbody id="financeTbody">
          <tr><td colspan="9" style="text-align:center;padding:32px;color:var(--neutral-400);">Loading records...</td></tr>
        </tbody>
        <tfoot id="financeTfoot" style="display:none;">
          <tr style="background:var(--neutral-50);">
            <td colspan="4" style="padding:12px 16px;font-weight:700;color:var(--neutral-700);">Totals</td>
            <td class="td-mono" style="font-weight:700;" id="totVal">Rs. 0</td>
            <td class="td-mono" style="font-weight:700;" id="totTrv">Rs. 0</td>
            <td class="td-mono" style="font-weight:700;" id="totRer">Rs. 0</td>
            <td class="td-mono" style="font-weight:700;color:var(--primary-600);" id="totGrand">Rs. 0</td>
            <td class="td-mono" style="font-weight:700;color:var(--info-600);" id="totVat">Rs. 0</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</DashboardLayout>

<script>
const API = 'http://localhost:8080';
const token = localStorage.getItem('aw_token') || '';

let allData = [];
let filtered = [];

async function loadData() {
  try {
    const res = await fetch(`${API}/api/valuations?per_page=1000`, {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await res.json();
    const items = (data.success && data.data?.items) ? data.data.items : [];
    
    // Simulate missing finance fields based on ID
    allData = items.map(v => {
      const valFee = (v.id % 5 + 1) * 500 + 1000;
      const trvFee = (v.id % 3) * 500;
      const rerFee = (v.id % 7 === 0) ? 500 : 0;
      const hasVat = (v.id % 2 === 0);
      
      const total = valFee + trvFee + rerFee;
      const vatAmt = hasVat ? Math.round(total * 0.18) : 0;
      
      return { ...v, valFee, trvFee, rerFee, hasVat, vatAmt, totalFee: total + vatAmt };
    });
  } catch(e) {
    console.error(e);
    allData = [];
  }
  window.loadReport();
}

window.loadReport = function() {
  const branch = document.getElementById('f_branch')?.value || '';
  const month  = document.getElementById('f_month')?.value || '';
  const year   = document.getElementById('f_year')?.value || '';
  const user   = document.getElementById('f_user')?.value || '';

  filtered = allData.filter(v => {
    if (branch && v.branch !== branch) return false;
    if (user && v.created_by !== user && v.user_id !== user) return false;
    
    if (month || year) {
      const d = v.created_at ? new Date(v.created_at) : null;
      if (d) {
        if (month && (d.getMonth() + 1) !== parseInt(month)) return false;
        if (year && d.getFullYear() !== parseInt(year)) return false;
      } else {
        return false;
      }
    }
    return true;
  });
  
  renderReport();
}

function renderReport() {
  const tbody = document.getElementById('financeTbody');
  
  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:32px;color:var(--neutral-400);">No finance records found</td></tr>';
    document.getElementById('financeTfoot').style.display = 'none';
    
    document.getElementById('totalRevenue').textContent = 'Rs. 0';
    document.getElementById('totalVal').textContent = '0';
    document.getElementById('avgFee').textContent = 'Rs. 0';
    document.getElementById('totalTravel').textContent = 'Rs. 0';
    return;
  }

  let sumVal = 0, sumTrv = 0, sumRer = 0, sumTotal = 0, sumVat = 0;

  tbody.innerHTML = filtered.map(r => {
    sumVal += r.valFee;
    sumTrv += r.trvFee;
    sumRer += r.rerFee;
    sumTotal += r.totalFee;
    sumVat += r.vatAmt;
    
    const d = r.created_at ? r.created_at.substring(0,10) : '—';
    const totalRaw = r.valFee + r.trvFee + r.rerFee;

    return `
      <tr>
        <td class="td-mono" style="color:var(--neutral-400);">#${r.id}</td>
        <td class="td-mono" style="font-weight:600;">${r.reg_no || '—'}</td>
        <td>${r.branch || '—'}</td>
        <td class="td-mono" style="font-size:.78rem;">${d}</td>
        <td class="td-mono">Rs. ${r.valFee.toLocaleString()}</td>
        <td class="td-mono">Rs. ${r.trvFee.toLocaleString()}</td>
        <td class="td-mono">${r.rerFee > 0 ? `Rs. ${r.rerFee.toLocaleString()}` : '—'}</td>
        <td class="td-mono" style="font-weight:700;">Rs. ${totalRaw.toLocaleString()}</td>
        <td>
          ${r.hasVat
            ? `<span class="badge badge-info">+Rs. ${r.vatAmt.toLocaleString()}</span>`
            : `<span class="badge badge-neutral">None</span>`
          }
        </td>
      </tr>
    `;
  }).join('');

  // Update Footer
  document.getElementById('totVal').textContent = 'Rs. ' + sumVal.toLocaleString();
  document.getElementById('totTrv').textContent = 'Rs. ' + sumTrv.toLocaleString();
  document.getElementById('totRer').textContent = 'Rs. ' + sumRer.toLocaleString();
  document.getElementById('totGrand').textContent = 'Rs. ' + (sumVal + sumTrv + sumRer).toLocaleString();
  document.getElementById('totVat').textContent = 'Rs. ' + sumVat.toLocaleString();
  document.getElementById('financeTfoot').style.display = '';

  // Update Summary Cards
  document.getElementById('totalRevenue').textContent = 'Rs. ' + sumTotal.toLocaleString();
  document.getElementById('totalVal').textContent = filtered.length.toLocaleString();
  document.getElementById('avgFee').textContent = 'Rs. ' + Math.round(sumTotal / filtered.length).toLocaleString();
  document.getElementById('totalTravel').textContent = 'Rs. ' + sumTrv.toLocaleString();
}

window.exportReport = function() {
  if (!filtered.length) { alert('No data to export.'); return; }
  
  const rows = [['ID', 'Register No', 'Branch', 'Date', 'Val Amount', 'Travel Amount', 'Re-report', 'Total', 'VAT']];
  filtered.forEach(r => {
    const d = r.created_at ? r.created_at.substring(0,10) : '';
    const totalRaw = r.valFee + r.trvFee + r.rerFee;
    rows.push([r.id, r.reg_no, r.branch, d, r.valFee, r.trvFee, r.rerFee, totalRaw, r.vatAmt]);
  });
  
  const csv = rows.map(r => r.join(',')).join('\\n');
  const blob = new Blob([csv], {type: 'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'finance_report.csv';
  a.click();
}

loadData();
</script>
