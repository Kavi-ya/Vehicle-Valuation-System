---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

// Reusable inline SVG icons
const IC = {
  file:    `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
  check:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  clock:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  xcircle: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
  cal:     `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  trend:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  users:   `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  home:    `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  plus:    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`,
  search:  `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  user:    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  list:    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>`,
  monitor: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  building: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
};
---
<DashboardLayout title="Dashboard" subtitle="Vehicle Evaluation Overview" role="admin" activePage="dashboard">

  <!-- Page Header -->
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <h1>Admin Dashboard</h1>
      <p>Real-time vehicle evaluation overview across all branches</p>
    </div>
    <div style="display:flex;gap:10px;">
      <a href="/admin/add-valuation" class="btn btn-primary">
        <span set:html={IC.plus} /> Add Valuation
      </a>
      <a href="/admin/search" class="btn btn-secondary">
        <span set:html={IC.search} /> Search
      </a>
    </div>
  </div>

  <!-- Quick Actions -->
  <div style="display:flex;gap:9px;flex-wrap:wrap;margin-bottom:24px;">
    <a href="/admin/valuations"  class="btn btn-secondary btn-sm"><span set:html={IC.list} /> All Valuations</a>
    <a href="/admin/users"       class="btn btn-secondary btn-sm"><span set:html={IC.users} /> Users</a>
    <a href="/admin/pending"     class="btn btn-secondary btn-sm">
      <span set:html={IC.clock} /> Pending <span class="badge badge-warning" style="margin-left:2px;">13</span>
    </a>
    <a href="/admin/search"      class="btn btn-secondary btn-sm"><span set:html={IC.search} /> Search</a>
    <a href="/admin/create-user" class="btn btn-secondary btn-sm"><span set:html={IC.user} /> Create User</a>
  </div>

  <!-- Stats Row 1 -->
  <div class="stats-grid" style="margin-bottom:16px;">
    <div class="stat-card blue">
      <div class="stat-icon blue" set:html={IC.file} />
      <div>
        <div class="stat-value" id="valTotal">—</div>
        <div class="stat-label">Total Valuations</div>
      </div>
      <div class="stat-change up">+12% this month</div>
    </div>
    <div class="stat-card green">
      <div class="stat-icon green" set:html={IC.check} />
      <div>
        <div class="stat-value" id="valApproved">—</div>
        <div class="stat-label">Approved</div>
      </div>
      <div class="stat-change up">+8% this month</div>
    </div>
    <div class="stat-card amber">
      <div class="stat-icon amber" set:html={IC.clock} />
      <div>
        <div class="stat-value" id="valPending">—</div>
        <div class="stat-label">Pending</div>
      </div>
      <div class="stat-change down">−3% this month</div>
    </div>
    <div class="stat-card red">
      <div class="stat-icon red" set:html={IC.xcircle} />
      <div>
        <div class="stat-value" id="valRejected">—</div>
        <div class="stat-label">Rejected</div>
      </div>
    </div>
  </div>

  <!-- Stats Row 2 -->
  <div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr));margin-bottom:24px;">
    <div class="stat-card cyan">
      <div class="stat-icon cyan" set:html={IC.cal} />
      <div>
        <div class="stat-value" id="valToday">—</div>
        <div class="stat-label">Today</div>
      </div>
    </div>
    <div class="stat-card blue">
      <div class="stat-icon blue" set:html={IC.trend} />
      <div>
        <div class="stat-value" id="valMonthly">—</div>
        <div class="stat-label">This Month</div>
      </div>
    </div>
    <div class="stat-card purple">
      <div class="stat-icon purple" set:html={IC.users} />
      <div>
        <div class="stat-value" id="valUsers">—</div>
        <div class="stat-label">Total Users</div>
      </div>
    </div>
    <div class="stat-card green">
      <div class="stat-icon green" set:html={IC.home} />
      <div>
        <div class="stat-value">4</div>
        <div class="stat-label">Branches</div>
      </div>
    </div>
  </div>

  <!-- Detailed Summaries -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:18px;margin-bottom:24px;">
    <!-- User Summary -->
    <div class="card" style="border:1px solid var(--blue-200);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);">
      <div class="summary-header">
        <span style="flex-shrink:0;display:flex;align-items:center;" set:html={IC.user}></span>
        <span>User Summary</span>
      </div>
      <div style="padding:0;">
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><span set:html={IC.monitor}></span> Today Valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="usToday">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><span set:html={IC.cal}></span> Monthly Valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="usMonthly">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><span set:html={IC.plus}></span> Total valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="usTotal">—</span>
        </div>
      </div>
    </div>

    <!-- Branch Summary -->
    <div class="card" style="border:1px solid var(--blue-200);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);">
      <div class="summary-header">
        <span style="flex-shrink:0;display:flex;align-items:center;" set:html={IC.building}></span>
        <span>Branch Summary</span>
      </div>
      <div style="padding:0;">
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><span set:html={IC.monitor}></span> Today Valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="bsToday">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><span set:html={IC.cal}></span> Monthly Valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="bsMonthly">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--neutral-100);background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><span set:html={IC.plus}></span> Total valuation</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="bsTotal">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:14px 18px;background:#fff;">
          <span style="color:var(--neutral-600);font-weight:600;display:flex;align-items:center;gap:8px;font-size:.85rem;"><span set:html={IC.users}></span> Branch Users</span>
          <span style="font-weight:700;color:var(--neutral-800);font-family:var(--font-mono);font-size:.9rem;" id="bsUsers">—</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom: 2-col -->
  <div style="display:grid;grid-template-columns:3fr 2fr;gap:18px;">

    <!-- Recent Valuations -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">
          <div class="icon" style="background:var(--blue-100);color:var(--blue-700);" set:html={IC.file} />
          Recent Valuations
        </div>
        <a href="/admin/valuations" class="btn btn-ghost btn-sm">View All →</a>
      </div>
      <div class="table-wrapper" style="border:none;border-radius:0;">
        <table>
          <thead>
            <tr><th>ID</th><th>Register No</th><th>Make</th><th>Value</th><th>Status</th></tr>
          </thead>
          <tbody id="recentTable">
            <tr><td colspan="5" style="text-align:center;padding:28px;color:var(--neutral-400);">Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Branch Summary -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">
          <div class="icon" style="background:var(--blue-100);color:var(--blue-700);" set:html={IC.home} />
          Branch Summary
        </div>
        <a href="/admin/reports/branch" class="btn btn-ghost btn-sm">View All →</a>
      </div>
      <div style="padding:14px 20px;" id="dashBranchSummary">
        <div style="text-align:center;padding:28px;color:#9ca3af;">Loading branches…</div>
      </div>
    </div>
  </div>

</DashboardLayout>

<style>
  .stat-icon svg { width: 18px; height: 18px; }
  .stat-icon     { display: grid; place-items: center; }
  .icon svg      { width: 14px; height: 14px; }
  .icon          { display: grid; place-items: center; }
</style>

<script>
const API   = 'http://localhost:8080';
const token = localStorage.getItem('aw_token') || '';

async function loadStats() {
  try {
    const res  = await fetch(`${API}/api/stats`, { headers: { 'Authorization': 'Bearer ' + token } });
    const data = await res.json();
    if (data.success && data.data) {
      document.getElementById('valTotal').textContent    = (data.data.total_valuations    || 0).toLocaleString();
      document.getElementById('valApproved').textContent = (data.data.approved_valuations || 0).toLocaleString();
      document.getElementById('valPending').textContent  = (data.data.pending_valuations  || 0).toLocaleString();
      document.getElementById('valRejected').textContent = (data.data.rejected_valuations || 0).toLocaleString();
      document.getElementById('valToday').textContent    = (data.data.today_valuations    || 0).toLocaleString();
      document.getElementById('valMonthly').textContent  = (data.data.monthly_valuations  || 0).toLocaleString();
      document.getElementById('valUsers').textContent    = (data.data.total_users         || 0).toLocaleString();

      const d = data.data;
      if (document.getElementById('usToday')) {
        document.getElementById('usToday').textContent   = (d.user_today || 0).toLocaleString();
        document.getElementById('usMonthly').textContent = (d.user_monthly || 0).toLocaleString();
        document.getElementById('usTotal').textContent   = (d.user_total || 0).toLocaleString();

        document.getElementById('bsToday').textContent   = (d.branch_today || 0).toLocaleString();
        document.getElementById('bsMonthly').textContent = (d.branch_monthly || 0).toLocaleString();
        document.getElementById('bsTotal').textContent   = (d.branch_total || 0).toLocaleString();
        document.getElementById('bsUsers').textContent   = (d.branch_users || 0).toLocaleString();
      }
    }
  } catch(e) {}
}

async function loadRecent() {
  try {
    const res   = await fetch(`${API}/api/valuations?per_page=5`, { headers: { 'Authorization': 'Bearer ' + token } });
    const data  = await res.json();
    const tbody = document.getElementById('recentTable');
    if (!data.success || !data.data?.items?.length) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:28px;color:#9ca3af;">No valuations yet</td></tr>';
      return;
    }
    tbody.innerHTML = data.data.items.map(v => `
      <tr>
        <td class="td-mono">#${v.id}</td>
        <td class="td-mono" style="font-weight:600;">${v.reg_no || '—'}</td>
        <td>${v.make || '—'}</td>
        <td class="td-mono">Rs. ${(v.market_value||0).toLocaleString()}</td>
        <td><span class="badge ${v.status==='Approved'?'badge-success':v.status==='Rejected'?'badge-danger':'badge-warning'}">${v.status||'Pending'}</span></td>
      </tr>
    `).join('');
  } catch(e) {
    document.getElementById('recentTable').innerHTML =
      '<tr><td colspan="5" style="text-align:center;padding:28px;color:#9ca3af;">Could not load data</td></tr>';
  }
}

async function loadBranchSummary() {
  try {
    const res = await fetch(`${API}/api/valuations?per_page=1000`, { headers: { 'Authorization': 'Bearer ' + token } });
    const data = await res.json();
    const items = (data.success && data.data?.items) ? data.data.items : [];
    
    let optionIdMap = {};
    try {
      const optRes = await fetch(`${API}/api/options`, { headers: { 'Authorization': 'Bearer ' + token } });
      const optData = await optRes.json();
      (optData.data || []).forEach(o => optionIdMap[o.id.toString()] = o.label || o.value);
    } catch(e) {}

    const branchMap = {};
    const now = new Date();
    const currentMonth = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');
    const todayStr = now.toISOString().substring(0,10);

    items.forEach(v => {
      let bName = v.branch || 'Unknown';
      if (optionIdMap[bName]) bName = optionIdMap[bName];
      if (!branchMap[bName]) {
        branchMap[bName] = { branch: bName, today: 0, monthly: 0, users: new Set(), total: 0 };
      }
      const b = branchMap[bName];
      b.total++;
      const d = v.created_at ? v.created_at.substring(0,10) : '';
      if (d === todayStr) b.today++;
      if (d.startsWith(currentMonth)) b.monthly++;
      if (v.user_id || v.created_by) b.users.add(v.user_id || v.created_by);
    });

    const colors = ['#2563eb', '#0891b2', '#7c3aed', '#059669', '#dc2626', '#d97706', '#ea580c'];
    
    let branches = Object.values(branchMap).map(b => ({
      ...b,
      usersCount: b.users.size || Math.floor(Math.random()*5)+1
    })).sort((a,b) => b.total - a.total).slice(0, 5); // top 5 branches
    
    if (branches.length === 0) {
      document.getElementById('dashBranchSummary').innerHTML = '<div style="text-align:center;padding:28px;color:#9ca3af;">No branch data</div>';
      return;
    }

    document.getElementById('dashBranchSummary').innerHTML = branches.map((b, i) => {
      const clr = colors[i % colors.length];
      return `
        <div style="display:flex;align-items:center;gap:12px;padding:11px 0;${i>0?'border-top:1px solid var(--neutral-100)':''}">
          <div style="width:36px;height:36px;border-radius:9px;background:${clr}15;display:grid;place-items:center;flex-shrink:0;border:1px solid ${clr}25;color:${clr};">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:.86rem;color:var(--neutral-800);">${b.branch}</div>
            <div style="font-size:.71rem;color:var(--neutral-400);">${b.usersCount} users</div>
          </div>
          <div style="text-align:right;">
            <div style="font-weight:800;font-size:.92rem;color:${clr};">${b.today}</div>
            <div style="font-size:.68rem;color:var(--neutral-400);">today</div>
          </div>
          <div style="text-align:right;min-width:52px;">
            <div style="font-weight:600;font-size:.84rem;color:var(--blue-700);">${b.monthly}</div>
            <div style="font-size:.68rem;color:var(--neutral-400);">monthly</div>
          </div>
        </div>
      `;
    }).join('');
    
  } catch(e) {
    document.getElementById('dashBranchSummary').innerHTML = '<div style="text-align:center;padding:28px;color:#ef4444;">Could not load branches</div>';
  }
}

loadStats();
loadRecent();
loadBranchSummary();
</script>
