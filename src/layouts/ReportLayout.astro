---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <style is:global>
        :root {
            --primary-blue: #0099cc;
            --primary-red: #cc0000;
            --bg-body: #f3f4f6; /* Light grey background */
            --bg-page: #ffffff; /* White paper */
            --text-main: #000000; /* Black text */
            --border-color: #e5e7eb; /* Light border */
            --bg-section: transparent; /* No section background */
            --box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        body {
            background-color: var(--bg-body);
            margin: 0;
            padding: 20px;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            color: var(--text-main);
            font-size: 12px;
            line-height: 1.2;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            color-scheme: light;
        }
        .a4-page {
            width: 210mm;
            min-height: 297mm;
            padding: 0;
            margin: 0 auto 20mm auto;
            background: var(--bg-page);
            box-shadow: var(--box-shadow);
            box-sizing: border-box;
            position: relative;
        }
        .page-break { page-break-before: always; margin-top: 20mm; }
        .section-title {
            background-color: var(--bg-section);
            padding: 5px 10px;
            font-weight: bold;
            margin: 15px 0 10px 0;
            border-left: 4px solid var(--primary-blue);
        }
        .data-row {
            display: grid;
            grid-template-columns: 210px 1fr;
            border-bottom: none;
            margin-bottom: 2px;
        }
        
        @media print {
            :root {
                --bg-body: white;
                --bg-page: white;
                --text-main: black;
                --border-color: #ccc;
                --bg-section: transparent;
                --box-shadow: none;
            }
            @page { size: A4 portrait; margin: 0; }
            body { background: white; padding: 0; margin: 0; color: black; }
            .a4-page { 
                width: 210mm; 
                height: 297mm; /* Full A4 sheet */
                min-height: 297mm;
                max-height: 297mm;
                margin: 0; 
                padding: 0; 
                box-shadow: none; 
                border: none; 
                overflow: hidden; /* Prevent spillover */
                page-break-inside: avoid;
            }
            .no-print { display: none !important; }
            .page-break { page-break-before: always; margin-top: 0; }
        }
    </style>
</head>
<body>
    <div class="no-print" style="text-align: center; margin-bottom: 20px;">
        <button onclick="window.print()" style="padding: 10px 20px; font-weight: bold; cursor: pointer;">
            🖨️ Print / Save as PDF
        </button>
    </div>
    <slot />
</body>
</html>
